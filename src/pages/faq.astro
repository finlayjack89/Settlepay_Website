---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../data/site.mjs';
import faq from '../data/content/faq.json';
import seoData from '../data/content/seo.json';
import { webPage, breadcrumbs, faqPage } from '../data/structuredData.mjs';

const seo = seoData.find((p) => p.path === '/faq/') ?? {};
const path = '/faq/';
const crumbs = [{ name: 'Home', path: '/' }, { name: 'FAQ', path }];

// Group questions by category, preserving order.
const cats = [];
for (const item of faq) {
  let g = cats.find((c) => c.name === item.category);
  if (!g) { g = { name: item.category, items: [] }; cats.push(g); }
  g.items.push(item);
}

// Stable per-question ids so objection answers are deep-linkable from
// outreach emails ("Are you FCA regulated?" gets a URL of its own).
const slug = (q) => q.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

// The three make-or-break answers, surfaced before the accordion.
const OBJECTIONS = [
  { q: 'Do you hold or touch my money?', tag: 'Your money' },
  { q: 'Are you FCA regulated?', tag: 'Regulation' },
  { q: 'How much does SettlePay cost?', tag: 'Cost' },
].map((o) => {
  const item = faq.find((i) => i.question === o.q);
  return item ? { ...o, id: slug(item.question), teaser: item.answer.split(/\n{2,}/)[0].slice(0, 150) } : null;
}).filter(Boolean);

const COST_ID = slug('How much does SettlePay cost?');

const esc = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
function linkify(s) {
  let t = esc(s);
  t = t.replace(/\bhttps?:\/\/[^\s<]+/g, (m) => {
    const trail = m.match(/[.,;:)]+$/);
    const url = trail ? m.slice(0, -trail[0].length) : m;
    return `<a href="${url}" target="_blank" rel="noopener">${url}</a>${trail ? trail[0] : ''}`;
  });
  t = t.replace(/\b[\w.+-]+@[\w.-]+\.[A-Za-z]{2,}\b/g, (e) => `<a href="mailto:${e}">${e}</a>`);
  return t;
}
const toParas = (answer) => answer.split(/\n{2,}/).map((p) => linkify(p.trim())).filter(Boolean);

const jsonLd = [
  webPage({ path, title: 'Frequently Asked Questions', description: seo.description, type: 'FAQPage' }),
  breadcrumbs(crumbs),
  faqPage(faq.map((i) => ({ question: i.question, answer: i.answer.replace(/\s*\n+\s*/g, ' ') }))),
];
---
<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  canonical={path}
  image="/og/faq.png"
  jsonLd={jsonLd}
>
  <header class="page-header">
    <div class="container">
      <Breadcrumbs items={crumbs} />
      <h1 class="page-header__title" data-reveal>Frequently Asked <span>Questions</span></h1>
      <p class="page-header__lead" data-reveal>
        Straight answers about how SettlePay works, who holds your money, security and compliance, and
        what it costs. Can't find what you need? <a href={`mailto:hello@settlepay.uk`}>Email us</a>.
      </p>
    </div>
  </header>

  <section class="faq-section">
    <div class="container">
      <!-- The make-or-break answers, before anything else. -->
      <div class="faq-objections" data-reveal>
        {OBJECTIONS.map((o) => (
          <a class="faq-objection" href={`#${o.id}`}>
            <span class="faq-objection__tag">{o.tag}</span>
            <span class="faq-objection__q">{o.q}</span>
            <span class="faq-objection__go">Read the full answer <Icon name="arrow" sw={2.5} /></span>
          </a>
        ))}
      </div>

      {cats.map((cat) => (
        <div class="faq-cat" data-reveal>
          <h2 class="faq-cat__title">{cat.name}</h2>
          <div class="faq-list">
            {cat.items.map((item) => (
              <details class="faq-item" id={slug(item.question)}>
                <summary class="faq-item__q">
                  <span>{item.question}</span>
                  <Icon name="chevron" sw={2.5} class="faq-chevron" />
                </summary>
                <div class="faq-item__a">
                  {toParas(item.answer).map((html) => <p set:html={html} />)}
                  {slug(item.question) === COST_ID && (
                    <p>
                      <button type="button" class="faq-inline-enquire" data-enquire>Send a short enquiry</button>
                      {' '}and we'll come back with a fixed written quote for your setup.
                    </p>
                  )}
                  <a class="faq-item__link" href={`#${slug(item.question)}`} data-faq-copy>
                    <Icon name="link" sw={2} /> Copy link to this answer
                  </a>
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mini-cta">
    <div class="container">
      <div class="mini-cta__inner" data-reveal>
        <h2 class="mini-cta__title">Still Have a Question?</h2>
        <p class="mini-cta__text">
          Send us a short enquiry and we'll talk it through — no jargon, no pressure.
        </p>
        <div class="mini-cta__actions">
          <Button variant="primary" icon="arrow" enquire>{SITE.cta.primary.label}</Button>
          <Button variant="secondary" href={SITE.cta.secondary.href}>{SITE.cta.secondary.label}</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
