---
/**
 * InlineCta — a contextual, in-flow enquiry prompt that appears after a
 * value-demonstrating section (the SQEase pattern: the ask surfaces where it
 * earns attention, not pinned to the bottom of the viewport). This replaces
 * the old mobile sticky bar, which could never fill the bottom behind iOS
 * Safari's floating toolbar. Reveals on scroll (`data-reveal`), so it "pops
 * up" as you reach it. Deliberately airy and light so it never competes with
 * the dark final CtaBand — one primary action, nothing else.
 */
import Button from '../Button.astro';
import { SITE } from '../../data/site.mjs';

const { line, source = 'inline-cta', label = SITE.cta.primary.label } = Astro.props;
---
<div class="inline-cta" data-reveal>
  <div class="container inline-cta__inner">
    <p class="inline-cta__line">{line}</p>
    <Button variant="primary" size="large" icon="arrow" enquire data-enquire-source={source}>{label}</Button>
  </div>
</div>

<style>
  .inline-cta {
    padding-block: clamp(2.25rem, 7vw, 3.5rem);
  }
  .inline-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
  }
  .inline-cta__line {
    margin: 0;
    max-width: 26ch;
    font-size: clamp(1.2rem, 4.5vw, 1.6rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--color-primary-brand);
    text-wrap: balance;
  }
  /* Full-width tap target on phones (matches the old bar's ergonomics); natural
     width from tablet up so it reads as a button, not a bar. */
  .inline-cta :global(.btn-primary) {
    width: 100%;
    max-width: 360px;
    justify-content: center;
  }
  @media (min-width: 640px) {
    .inline-cta :global(.btn-primary) { width: auto; }
  }
</style>
