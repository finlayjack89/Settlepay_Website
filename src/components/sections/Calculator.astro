---
import Icon from '../Icon.astro';
import Button from '../Button.astro';
import SectionHeader from '../SectionHeader.astro';
import { SITE } from '../../data/site.mjs';

// Initial values (JS keeps them live)
const payments = 120;
const mins = 12;
const rate = 30;
const hours = Math.round((payments * mins) / 60);
const cost = hours * rate;
const hoursY = hours * 12;
const daysY = Math.round(hoursY / 7.5); // 7.5h working day
const costY = cost * 12;
const pPct = ((payments - 10) / (600 - 10)) * 100;
const mPct = ((mins - 2) / (30 - 2)) * 100;
const rPct = ((rate - 15) / (150 - 15)) * 100;
// `--fill` positions the track gradient (see .calculator__range); JS keeps it live.
const fill = (pct) => `--fill: ${pct}%`;
---
<section class="calculator section-pad" data-screen-label="ROI calculator">
  <div class="container" id="savings">
    <SectionHeader
      align="left"
      eyebrow="See the impact"
      sentence={true}
      title="Admin Time "
      blue="Saved"
      subtitle="See how many hours you could reclaim each month by replacing manual bank transfers with automated card collection."
    />
    <div class="calculator__grid" data-calculator>
      <div class="calculator__inputs">
        <div class="calculator__input-group">
          <label class="calculator__label" for="calc-payments">Payments collected per month</label>
          <div class="calculator__slider-row">
            <input
              type="range" id="calc-payments" min="10" max="600" step="10" value={payments}
              class="calculator__range" data-range="payments"
              aria-label="Payments collected per month" style={fill(pPct)}
            />
            <span class="calculator__slider-value" data-val="payments">{payments}</span>
          </div>
        </div>
        <div class="calculator__input-group">
          <label class="calculator__label" for="calc-mins">Minutes spent reconciling each payment by hand</label>
          <div class="calculator__slider-row">
            <input
              type="range" id="calc-mins" min="2" max="30" step="1" value={mins}
              class="calculator__range" data-range="mins"
              aria-label="Minutes spent reconciling each payment by hand" style={fill(mPct)}
            />
            <span class="calculator__slider-value" data-val="mins">{mins} min</span>
          </div>
        </div>
        <div class="calculator__input-group">
          <label class="calculator__label" for="calc-rate">Your hourly rate (£)</label>
          <div class="calculator__slider-row">
            <input
              type="range" id="calc-rate" min="15" max="150" step="5" value={rate}
              class="calculator__range" data-range="rate"
              aria-label="Your hourly rate in pounds" style={fill(rPct)}
            />
            <span class="calculator__slider-value" data-val="rate">£{rate}</span>
          </div>
        </div>
      </div>

      <div class="calculator__results">
        <div class="calculator__result-card calculator__result-card--highlight">
          <div class="calculator__result-icon calculator__result-icon--blue"><Icon name="card" sw={1.5} /></div>
          <div>
            <div class="calculator__result-value" data-out="cost">£{cost.toLocaleString()}</div>
            <div class="calculator__result-label">Estimated admin cost reclaimed per month</div>
          </div>
        </div>
        <div class="calculator__result-card">
          <div class="calculator__result-icon calculator__result-icon--blue"><Icon name="clock" sw={1.5} /></div>
          <div>
            <div class="calculator__result-value" data-out="hours">{hours} hrs</div>
            <div class="calculator__result-label">Admin hours saved per month</div>
          </div>
        </div>
        <div class="calculator__result-card">
          <div class="calculator__result-icon"><Icon name="refresh" sw={1.5} /></div>
          <div>
            <div class="calculator__result-value">Zero</div>
            <div class="calculator__result-label">Manual reconciliation tasks</div>
          </div>
        </div>
        <div class="calculator__result-card">
          <div class="calculator__result-icon calculator__result-icon--green"><Icon name="shield" sw={1.5} /></div>
          <div>
            <div class="calculator__result-value" data-out="matched">{payments}</div>
            <div class="calculator__result-label">Payments auto-matched to invoices</div>
          </div>
        </div>
        {/* The year view is what lands with this audience: months are
            abstract, "working days a year" is a holiday. Derived live from
            the user's own inputs — never an invented figure. */}
        <p class="calculator__annual" data-out="annual" aria-live="polite">
          Over a year that's <strong>{hoursY.toLocaleString()} hours</strong> — {daysY.toLocaleString()}
          working days — about <strong>£{costY.toLocaleString()}</strong> in admin time reclaimed.
        </p>
      </div>
    </div>

    <p class="calculator__disclaimer">These figures are based on the numbers you enter — your actual savings will vary.</p>

    <div class="calculator__cta">
      <Button variant="primary" icon="arrow" enquire>{SITE.cta.primary.label}</Button>
      <p class="calculator__cta-note">Every project is a fixed written quote agreed before work begins — no retainers, no open-ended bills.</p>
    </div>
  </div>
</section>
