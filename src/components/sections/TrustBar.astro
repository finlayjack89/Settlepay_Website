---
import Icon from '../Icon.astro';

const trust = [
  { icon: 'card', tone: '', title: 'Modern Processors', text: 'FCA-regulated: Stripe, Adyen & more' },
  { icon: 'shield', tone: 'green', title: 'We Never Hold Funds', text: 'They settle straight to your bank' },
  { icon: 'lock', tone: 'purple', title: 'Security, Handled', text: 'PCI DSS via your processor' },
  { icon: 'check', tone: 'amber', title: 'No Lock-In, Ever', text: 'You own your account and page' },
];
---
<section class="trust section-pad" data-screen-label="Trust bar">
  <div class="container">
    <div class="trust__inner">
      <div class="trust__badge-group">
        {trust.map((b) => (
          <div class="trust__badge">
            <div class={'trust__badge-icon' + (b.tone ? ' trust__badge-icon--' + b.tone : '')}>
              <Icon name={b.icon} sw={1.5} />
            </div>
            <div>
              <div class="trust__badge-title">{b.title}</div>
              <div class="trust__badge-text">{b.text}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Deterministic, always-balanced grid (overrides the flex-wrap from styles.css). */
  .trust__badge-group {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem 2rem;
    align-items: start;
  }
  .trust__badge { align-items: flex-start; }
  @media (max-width: 880px) {
    .trust__badge-group { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .trust__badge-group { grid-template-columns: 1fr; }
  }
</style>
