# Secrets for the `enquiry` Edge Function.
# Copy to `.env` (gitignored) and set with:
#   supabase secrets set --env-file supabase/functions/enquiry/.env
#
# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by
# Supabase at runtime — do NOT set them here.

# Resend API key (https://resend.com → API Keys). Secret.
RESEND_API_KEY=

# Where lead notifications are sent (a real, monitored inbox).
LEAD_NOTIFY_TO=hello@settlepay.uk

# Verified Resend sender. The domain must be verified in Resend (DNS records).
LEAD_NOTIFY_FROM=SettlePay <notifications@settlepay.uk>

# Lock CORS to the live site in production (use * only while testing).
ALLOWED_ORIGIN=https://settlepay.uk
