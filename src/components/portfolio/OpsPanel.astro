---
/* "Beyond the page" back-office mockup: the payment-management view a client
   gets alongside their payment page. Deliberately the SAME calm ops design on
   every case study — the page is bespoke to the brand, the management layer is
   the consistent SettlePay system behind it. Data from portfolio.mjs
   caseStudy.ops; the client's brand accent appears only as the avatar dot.
   Illustrative UI — statuses and names are fictional demo data. */
import Chrome from '../previews/Chrome.astro';
import Icon from '../Icon.astro';

const { ops, accent = '#0F172A' } = Astro.props;
const statusMod = {
  paid: 'ops-status--paid',
  due: 'ops-status--due',
  reminder: 'ops-status--reminder',
  overdue: 'ops-status--overdue',
  scheduled: 'ops-status--scheduled',
};
---
<div class="mok ops">
  <Chrome url={ops.url} dark />
  <div class="ops__body">
    <div class="ops__head">
      <div>
        <div class="ops__title">{ops.title}</div>
        <div class="ops__subtitle">{ops.subtitle}</div>
      </div>
      <span class="ops__sync"><Icon name="refresh" sw={2} />{ops.sync}</span>
    </div>
    <div class="ops__rows" role="list">
      {ops.rows.map((r) => (
        <div class="ops-row" role="listitem">
          <span class="ops-row__dot" style={`background:${accent}`} aria-hidden="true"></span>
          <div class="ops-row__main">
            <span class="ops-row__ref">{r.ref}</span>
            <span class="ops-row__who">{r.who}</span>
            <span class="ops-row__sub">{r.sub}</span>
          </div>
          <span class="ops-row__amount">{r.amount}</span>
          <span class={'ops-status ' + (statusMod[r.status] ?? 'ops-status--due')}>{r.label}</span>
        </div>
      ))}
    </div>
    <div class="ops__feed">
      <Icon name="sparkles" sw={1.8} />
      <span>{ops.feed}</span>
    </div>
  </div>
</div>
