---
/**
 * TrustBar — dated, badge-only trust strip directly under the hero
 * (adoption #2: Chase's badge row + Monzo's dated caption). External marks
 * only, one dated caption, no self-claims; the green pill names the one
 * real live client. Update the "Correct as of" date when marks change.
 */
const marks = ['Visa', 'Mastercard', 'Amex', 'PayPal'];
---
<section class="trust-strip" data-screen-label="Trust strip">
  <div class="container">
    <div class="trust-strip__row">
      <div class="trust-strip__marks">
        {marks.map((m) => (
          <span class="trust-strip__mark"><img src={`/assets/payment/${m}.svg`} alt={m} loading="lazy" /></span>
        ))}
        <span class="trust-strip__mark trust-strip__mark--wallet">
          <img src="/assets/payment/apple-logo.svg" alt="" loading="lazy" /> Pay
        </span>
        <span class="trust-strip__mark trust-strip__mark--wallet">
          <img src="/assets/payment/google-g.svg" alt="" loading="lazy" /> Pay
        </span>
      </div>
      <p class="trust-strip__caption">
        Payments processed by FCA-regulated partners · Correct as of July 2026
      </p>
      <a class="trust-strip__live" href="/work/lockdales-auctioneers/">Live with Lockdales Auctioneers</a>
    </div>
  </div>
</section>
