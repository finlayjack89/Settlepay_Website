---
/**
 * Marsh & Vale Plumbing & Heating — pay-an-invoice demo.
 * FLAGSHIP HYBRID: mock card flow by default; when the site is built with
 * PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY set to a genuine TEST key (pk_test_…),
 * the mock card fields are replaced at build time by a real Stripe Payment
 * Element running in test mode (see docs/PORTFOLIO-DEMOS.md). With no key —
 * the default — the rendered HTML and behaviour are identical to the
 * original mock. Never reference a Stripe SECRET key anywhere in this repo.
 *
 * Fictional brand-world: deep green + copper, sturdy grotesque type, 4-8px
 * corners — deliberately NOT SettlePay's pill/24px language or blue.
 */
import Chrome from '../../previews/Chrome.astro';
import Icon from '../../Icon.astro';

const cardMarks = [
  { brand: 'visa', file: 'Visa.svg', label: 'Visa' },
  { brand: 'mastercard', file: 'Mastercard.svg', label: 'Mastercard' },
  { brand: 'amex', file: 'Amex.svg', label: 'American Express' },
];

// Real mode only with a genuine TEST publishable key (publishable keys are
// safe client-side). Anything else — empty, placeholder, pk_live_… — falls
// back to the mock.
const rawStripeKey = (import.meta.env.PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY ?? '').trim();
const stripeKey = rawStripeKey.startsWith('pk_test_') ? rawStripeKey : '';
const stripeEndpoint = stripeKey
  ? (import.meta.env.PUBLIC_STRIPE_DEMO_ENDPOINT ?? '').trim()
  : '';
---
<div
  class="mok mvp"
  data-mv-demo
  data-mv-stripe-key={stripeKey || undefined}
  data-mv-stripe-endpoint={stripeEndpoint || undefined}
>
  <Chrome url="pay.marshandvale.co.uk/invoice/INV-2147" />
  <div class="mvp__body">

    <header class="mvp__masthead">
      <span class="mvp__mark" aria-hidden="true">
        <svg viewBox="0 0 40 40" width="40" height="40" role="img" aria-hidden="true">
          <rect x="1" y="1" width="38" height="38" rx="7" fill="#B87333" />
          <path
            d="M9.5 28.5V12.5l10.5 13 10.5-13v16"
            fill="none"
            stroke="#F5F2EB"
            stroke-width="2.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="mvp__brand">
        <span class="mvp__brand-name">Marsh &amp; Vale</span>
        <span class="mvp__brand-trade">Plumbing &amp; Heating</span>
      </span>
      <span class="mvp__masthead-ref">Invoice INV-2147</span>
    </header>

    <section class="mvp__invoice" aria-label="Invoice summary">
      <div class="mvp__invoice-top">
        <div class="mvp__invoice-what">
          <span class="mvp__eyebrow">Invoice INV-2147 · Issued Mon 8 June</span>
          <h3 class="mvp__invoice-title">Boiler Service &amp; Thermostat Replacement</h3>
          <p class="mvp__invoice-meta">14 Alder Row, Saxmundham · Job completed Fri 5 June</p>
        </div>
        <span class="mvp__chip mvp__chip--due" data-mv-chip-due>Due now</span>
        <span class="mvp__chip mvp__chip--paid" data-mv-chip-paid hidden>Paid</span>
      </div>
      <dl class="mvp__lines">
        <div class="mvp__line">
          <dt>Labour — annual service &amp; thermostat fitting</dt>
          <dd>£240.00</dd>
        </div>
        <div class="mvp__line">
          <dt>Parts — programmable room thermostat</dt>
          <dd>£82.00</dd>
        </div>
        <div class="mvp__line">
          <dt>VAT (20%)</dt>
          <dd>£64.40</dd>
        </div>
        <div class="mvp__line mvp__line--total">
          <dt>Total due</dt>
          <dd>£386.40</dd>
        </div>
      </dl>
      <p class="mvp__invoice-note">
        <Icon name="phone" sw={2} />
        Any bother with the new thermostat, just give us a ring.
      </p>
    </section>

    <div class="mvp__pay" data-mv-pay>
      <div class="mvp__wallets">
        <button type="button" class="mvp__wallet mvp__wallet--apple" data-mv-wallet>
          <img src="/assets/payment/apple-logo.svg" alt="" class="mvp__wallet-apple" />
          <span>Pay</span>
          <span class="mvp__sr">Apple Pay</span>
        </button>
        <button type="button" class="mvp__wallet mvp__wallet--google" data-mv-wallet>
          <img src="/assets/payment/google-g.svg" alt="" class="mvp__wallet-google" />
          <span>Pay</span>
          <span class="mvp__sr">Google Pay</span>
        </button>
      </div>
      <p class="mvp__wallet-note" data-mv-wallet-note hidden>
        Available on the live page — use the card form in this demo.
      </p>

      <div class="mvp__divider" role="separator" aria-label="Or pay by card">
        <span>Or pay by card</span>
      </div>

      {stripeKey ? (
        <p class="mvp__hint">
          Stripe test mode — a real card form, no real charges. Demo cards: 4242 4242 4242 4242
          succeeds, 4000 0027 6000 3184 asks for a 3D Secure check, 4000 0000 0000 0002 declines.
          Use any future expiry and any CVC.
        </p>
      ) : (
        <p class="mvp__hint">
          Demo cards: 4242 4242 4242 4242 succeeds, 4000 0000 0000 0002 declines
        </p>
      )}

      <form class="mvp__form" data-mv-form novalidate>
        {stripeKey ? (
          <div class="mvp__field" data-mv-field="stripe">
            <p class="mvp__stripe-loading" data-mv-stripe-loading>
              Loading the secure card form…
            </p>
            <div class="mvp__stripe-mount" data-mv-stripe-mount></div>
            <p class="mvp__error" data-mv-error hidden>
              <Icon name="close" sw={2.5} /><span data-mv-error-text></span>
            </p>
          </div>
        ) : (
        <>
        <div class="mvp__field" data-mv-field="name">
          <label class="mvp__label">
            <span class="mvp__label-text">Name on card</span>
            <input
              class="mvp__input"
              type="text"
              name="cardholder"
              autocomplete="cc-name"
              spellcheck="false"
              placeholder="E. Hartley"
              data-mv-input="name"
            />
          </label>
          <p class="mvp__error" data-mv-error hidden>
            <Icon name="close" sw={2.5} /><span data-mv-error-text></span>
          </p>
        </div>

        <div class="mvp__field" data-mv-field="number">
          <label class="mvp__label">
            <span class="mvp__label-text">Card number</span>
            <span class="mvp__input-wrap">
              <input
                class="mvp__input"
                type="text"
                name="cardnumber"
                autocomplete="cc-number"
                inputmode="numeric"
                spellcheck="false"
                placeholder="1234 5678 9012 3456"
                data-mv-input="number"
              />
              <span class="mvp__brands" data-mv-brands>
                {cardMarks.map((m) => (
                  <img
                    src={`/assets/payment/${m.file}`}
                    alt={m.label}
                    data-mv-brand={m.brand}
                    class="mvp__brand-mark"
                  />
                ))}
              </span>
            </span>
          </label>
          <p class="mvp__error" data-mv-error hidden>
            <Icon name="close" sw={2.5} /><span data-mv-error-text></span>
          </p>
        </div>

        <div class="mvp__field-row">
          <div class="mvp__field" data-mv-field="expiry">
            <label class="mvp__label">
              <span class="mvp__label-text">Expiry</span>
              <input
                class="mvp__input"
                type="text"
                name="cc-exp"
                autocomplete="cc-exp"
                inputmode="numeric"
                spellcheck="false"
                placeholder="MM / YY"
                data-mv-input="expiry"
              />
            </label>
            <p class="mvp__error" data-mv-error hidden>
              <Icon name="close" sw={2.5} /><span data-mv-error-text></span>
            </p>
          </div>
          <div class="mvp__field" data-mv-field="cvc">
            <label class="mvp__label">
              <span class="mvp__label-text">Security code</span>
              <input
                class="mvp__input"
                type="text"
                name="cvc"
                autocomplete="cc-csc"
                inputmode="numeric"
                spellcheck="false"
                placeholder="CVC"
                data-mv-input="cvc"
              />
            </label>
            <p class="mvp__error" data-mv-error hidden>
              <Icon name="close" sw={2.5} /><span data-mv-error-text></span>
            </p>
          </div>
        </div>
        </>
        )}

        <button type="submit" class="mvp__paybtn" data-mv-submit>
          <span class="mvp__paybtn-label">Pay £386.40</span>
          <span class="mvp__paybtn-busy" data-mv-busy hidden>
            <span class="mvp__spinner" aria-hidden="true"></span>Processing…
          </span>
        </button>
      </form>
    </div>

    <div class="mvp__panel mvp__panel--success" data-mv-success hidden>
      <span class="mvp__panel-icon mvp__panel-icon--ok"><Icon name="check" sw={2.5} /></span>
      <h3 class="mvp__panel-title" data-mv-success-title>Payment Received</h3>
      <p class="mvp__panel-amount">£386.40</p>
      <p class="mvp__panel-text">Invoice INV-2147 is settled. A receipt has been emailed to you.</p>
      <p class="mvp__panel-fine">
        Funds settle directly to Marsh &amp; Vale's own bank account.
      </p>
      {stripeKey && (
        <p class="mvp__panel-validated" data-mv-validated hidden>
          Validated by Stripe in test mode — confirmation endpoint not configured in this preview.
        </p>
      )}
      <button type="button" class="mvp__ghostbtn" data-mv-reset>Restart Demo</button>
    </div>

    <div class="mvp__panel mvp__panel--declined" data-mv-declined hidden>
      <span class="mvp__panel-icon mvp__panel-icon--err"><Icon name="close" sw={2.5} /></span>
      <h3 class="mvp__panel-title">Your Card Was Declined</h3>
      <p class="mvp__panel-text">
        No charge has been made. Check the card details, or try a different card.
      </p>
      <button type="button" class="mvp__ghostbtn" data-mv-retry>Try Again</button>
    </div>

    <p class="mvp__sr" data-mv-status role="status" aria-live="polite"></p>

    <footer class="mvp__foot">
      <p class="mvp__foot-secure">
        <Icon name="lock" sw={2} />
        Secured by an FCA-regulated processor · Funds go straight to Marsh &amp; Vale's account
      </p>
      <p class="mvp__foot-demo">Illustrative demo — no real payments are taken.</p>
    </footer>

  </div>
</div>

<style>
  /* Brand-world palette — Marsh & Vale only. 4-8px corner language throughout. */
  .mvp {
    --mv-green: #1e3a2f;
    --mv-green-deep: #14291f;
    --mv-copper: #b87333;
    --mv-copper-dark: #9a5d26;
    --mv-cream: #f5f2eb;
    --mv-paper: #fffdf8;
    --mv-ink: #1b2b22;
    --mv-ink-soft: rgba(27, 43, 34, 0.62);
    --mv-line: rgba(27, 43, 34, 0.14);
    --mv-font: 'Helvetica Neue', Helvetica, Arial, system-ui, sans-serif;
    font-family: var(--mv-font);
    color: var(--mv-ink);
  }
  /* classes below set display values that would otherwise beat the UA [hidden] rule */
  .mvp [hidden] {
    display: none !important;
  }
  .mvp__body {
    background: var(--mv-cream);
    padding: 0 0 0.25rem;
  }
  .mvp__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* Masthead ------------------------------------------------------------- */
  .mvp__masthead {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 1.4rem;
    background: var(--mv-green);
    color: var(--mv-cream);
  }
  .mvp__mark svg {
    display: block;
    border-radius: 8px;
  }
  .mvp__brand {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .mvp__brand-name {
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: 0.01em;
  }
  .mvp__brand-trade {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #cdaa7d;
  }
  .mvp__masthead-ref {
    margin-left: auto;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(245, 242, 235, 0.72);
    border: 1px solid rgba(245, 242, 235, 0.28);
    border-radius: 4px;
    padding: 0.3rem 0.55rem;
    white-space: nowrap;
  }

  /* Invoice summary ------------------------------------------------------ */
  .mvp__invoice {
    margin: 1.1rem 1.4rem 0;
    background: var(--mv-paper);
    border: 1px solid var(--mv-line);
    border-radius: 6px;
    padding: 1.05rem 1.15rem 0.9rem;
  }
  .mvp__invoice-top {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .mvp__invoice-what { min-width: 0; }
  .mvp__eyebrow {
    display: block;
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--mv-copper-dark);
    margin-bottom: 0.3rem;
  }
  .mvp__invoice-title {
    margin: 0;
    font-family: var(--mv-font);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--mv-ink);
  }
  .mvp__invoice-meta {
    margin: 0.25rem 0 0;
    font-size: 0.74rem;
    color: var(--mv-ink-soft);
  }
  .mvp__chip {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.55rem;
    border-radius: 4px;
  }
  .mvp__chip--due {
    color: var(--mv-copper-dark);
    background: rgba(184, 115, 51, 0.12);
    border: 1px solid rgba(184, 115, 51, 0.3);
  }
  .mvp__chip--paid {
    color: var(--mv-green);
    background: rgba(30, 58, 47, 0.1);
    border: 1px solid rgba(30, 58, 47, 0.3);
  }
  .mvp__lines {
    margin: 0.9rem 0 0;
    border-top: 1px solid var(--mv-line);
  }
  .mvp__line {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--mv-line);
    font-size: 0.8rem;
  }
  .mvp__line dt { color: var(--mv-ink-soft); }
  .mvp__line dd {
    margin: 0;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .mvp__line--total {
    border-bottom: none;
    padding-top: 0.65rem;
    font-size: 0.92rem;
  }
  .mvp__line--total dt {
    color: var(--mv-ink);
    font-weight: 700;
  }
  .mvp__line--total dd {
    font-weight: 700;
    font-size: 1.1rem;
  }
  .mvp__invoice-note {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0.55rem 0 0;
    padding-top: 0.6rem;
    border-top: 1px solid var(--mv-line);
    font-size: 0.74rem;
    font-style: italic;
    color: var(--mv-ink-soft);
  }
  .mvp__invoice-note :global(svg) {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    color: var(--mv-copper);
  }

  /* Wallets -------------------------------------------------------------- */
  .mvp__pay { padding: 1.1rem 1.4rem 1.3rem; }
  .mvp__wallets {
    display: flex;
    gap: 0.7rem;
  }
  .mvp__wallet {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    height: 44px;
    border-radius: 6px;
    border: 1px solid transparent;
    font-family: var(--mv-font);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity var(--ease-snappy);
  }
  .mvp__wallet:hover { opacity: 0.88; }
  .mvp__wallet:focus-visible {
    outline: 2px solid var(--mv-copper);
    outline-offset: 2px;
  }
  .mvp__wallet--apple {
    background: #000;
    color: #fff;
  }
  .mvp__wallet-apple {
    width: 16px;
    height: 20px;
    margin-top: -2px;
    filter: brightness(0) invert(1); /* white apple glyph on the black button */
  }
  .mvp__wallet--google {
    background: #fff;
    color: #3c4043;
    border-color: #dadce0;
  }
  .mvp__wallet-google {
    width: 20px;
    height: 20px;
  }
  .mvp__wallet-note {
    margin: 0.55rem 0 0;
    font-size: 0.72rem;
    text-align: center;
    color: var(--mv-ink-soft);
  }

  /* Divider + hint ------------------------------------------------------- */
  .mvp__divider {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 1rem 0 0.8rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--mv-ink-soft);
  }
  .mvp__divider::before,
  .mvp__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--mv-line);
  }
  .mvp__hint {
    margin: 0 0 0.9rem;
    padding: 0.45rem 0.65rem;
    border: 1px dashed rgba(184, 115, 51, 0.45);
    border-radius: 4px;
    background: rgba(184, 115, 51, 0.07);
    font-size: 0.7rem;
    line-height: 1.5;
    color: var(--mv-copper-dark);
    font-variant-numeric: tabular-nums;
  }

  /* Card form ------------------------------------------------------------ */
  .mvp__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .mvp__field-row {
    display: flex;
    gap: 0.7rem;
  }
  .mvp__field-row .mvp__field { flex: 1; min-width: 0; }
  .mvp__label { display: block; }
  .mvp__label-text {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mv-ink-soft);
    margin-bottom: 0.32rem;
  }
  .mvp__input-wrap {
    position: relative;
    display: block;
  }
  .mvp__input {
    display: block;
    width: 100%;
    height: 42px;
    padding: 0 0.7rem;
    border: 1px solid var(--mv-line);
    border-radius: 6px;
    background: var(--mv-paper);
    font-family: var(--mv-font);
    font-size: 0.88rem;
    color: var(--mv-ink);
    font-variant-numeric: tabular-nums;
    transition: border-color var(--ease-snappy), box-shadow var(--ease-snappy);
    box-sizing: border-box;
  }
  .mvp__input::placeholder { color: rgba(27, 43, 34, 0.35); }
  .mvp__input:focus {
    outline: none;
    border-color: var(--mv-copper);
    box-shadow: 0 0 0 3px rgba(184, 115, 51, 0.18);
  }
  .mvp__input[aria-invalid='true'] {
    border-color: var(--color-error);
  }
  .mvp__input[aria-invalid='true']:focus {
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.14);
  }
  .mvp__brands {
    position: absolute;
    right: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: 4px;
    pointer-events: none;
  }
  .mvp__brand-mark {
    height: 15px;
    width: auto;
    transition: opacity var(--ease-snappy);
  }
  .mvp__brands[data-active] .mvp__brand-mark { opacity: 0.22; }
  .mvp__brands[data-active] .mvp__brand-mark.is-match { opacity: 1; }
  .mvp__field--number-padded .mvp__input { padding-right: 6.2rem; }

  .mvp__error {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin: 0.32rem 0 0;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-error);
  }
  .mvp__error :global(svg) {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* Stripe Payment Element mount (real test mode only) -------------------- */
  .mvp__stripe-loading {
    margin: 0;
    padding: 0.9rem 0.7rem;
    border: 1px dashed var(--mv-line);
    border-radius: 6px;
    background: var(--mv-paper);
    font-size: 0.78rem;
    text-align: center;
    color: var(--mv-ink-soft);
  }
  .mvp__stripe-mount {
    min-height: 0;
    transition: min-height var(--ease-cinematic);
  }
  .mvp__stripe-mount.is-ready {
    min-height: 90px;
  }

  /* Pay button ----------------------------------------------------------- */
  .mvp__paybtn {
    margin-top: 0.35rem;
    height: 46px;
    border: none;
    border-radius: 6px;
    background: var(--mv-copper);
    color: #fff;
    font-family: var(--mv-font);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background var(--ease-snappy), transform var(--ease-snappy);
  }
  .mvp__paybtn:hover:not(:disabled) { background: var(--mv-copper-dark); }
  .mvp__paybtn:active:not(:disabled) { transform: scale(0.99); }
  .mvp__paybtn:focus-visible {
    outline: 2px solid var(--mv-green);
    outline-offset: 2px;
  }
  .mvp__paybtn:disabled {
    cursor: default;
    opacity: 0.85;
  }
  .mvp__paybtn-busy {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mvp__paybtn-busy[hidden] { display: none; }
  .mvp__spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    animation: mvp-spin 0.7s linear infinite;
  }
  @keyframes mvp-spin {
    to { transform: rotate(360deg); }
  }

  /* Result panels --------------------------------------------------------- */
  .mvp__panel {
    margin: 1.1rem 1.4rem 1.3rem;
    padding: 1.6rem 1.2rem 1.4rem;
    background: var(--mv-paper);
    border: 1px solid var(--mv-line);
    border-radius: 6px;
    text-align: center;
  }
  .mvp__panel-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
