---
/* PreviewStudio — "See your payment page" URL-driven brand customiser.

   The visitor pastes their website address; we call the `brand-preview` Edge
   Function, which reads their public brand (name, logo, colour, font) via
   Brandfetch and drafts compliant microcopy. The detected brand is poured into
   the same mockup checkout used on /work/, then the visitor can tweak colour /
   scenario / name by hand. If extraction fails (or the backend isn't reachable
   yet) the controls still work as a manual fallback.

   A/B split-test: when the backend runs in COPY_PROVIDER=both mode it returns a
   `copyAB` object with a Claude variant and an OpenAI variant. In that case we
   render TWO payment pages side by side — same brand (logo, colour, font), the
   only difference is the microcopy — each labelled with its model, so you can
   compare the two pages directly.

   Mockup-world: the prospect's own colour drives the demo brand, so any colour —
   including blue — is legitimate inside the checkout. The SettlePay page chrome
   around it keeps the reserved-blue rules (the single primary action here is
   "Generate Preview"). Illustrative only; no real payments; not affiliated with
   any brand whose URL is entered. */
import Icon from '../Icon.astro';
import Button from '../Button.astro';
import CheckoutPreview from './CheckoutPreview.astro';
import { SITE } from '../../data/site.mjs';

const swatches = [
  { id: 'teal', hex: '#0F766E' },
  { id: 'indigo', hex: '#4F46E5' },
  { id: 'plum', hex: '#9333EA' },
  { id: 'rose', hex: '#E11D48' },
  { id: 'amber', hex: '#B45309' },
  { id: 'slate', hex: '#0F172A' },
];
const defaultHex = swatches[0].hex;
---
<div
  class="ps"
  data-ps
  data-default-name="Your Business"
  data-default-colour={defaultHex}
  data-endpoint={SITE.previewEndpoint}
  style={`--bs-accent:${defaultHex};--bs-on-accent:#ffffff`}
>
  <!-- Fast path: paste a URL -->
  <form class="ps__urlbar" data-ps-form novalidate>
    <label class="ps__url-label" for="ps-url">Your website address</label>
    <div class="ps__url-row">
      <span class="ps__url-globe" aria-hidden="true"><Icon name="globe" sw={1.8} /></span>
      <input
        class="ps__url-input"
        id="ps-url"
        type="url"
        inputmode="url"
        autocomplete="url"
        spellcheck="false"
        placeholder="yourbusiness.co.uk"
        data-ps-url
        aria-describedby="ps-status"
      />
      <Button variant="primary" type="submit" icon="arrow" data-ps-generate>Generate Preview</Button>
    </div>
    <p class="ps__status" id="ps-status" data-ps-status aria-live="polite">
      Paste your site and we'll sketch a payment page in your brand — in seconds.
    </p>
  </form>

  <div class="ps__grid">
    <!-- Controls (SettlePay UI) — also the manual fallback -->
    <div class="ps__controls">
      <div class="ps__field">
        <label class="ps__label" for="ps-name">Business name</label>
        <input
          class="ps__input"
          id="ps-name"
          type="text"
          maxlength="32"
          value="Your Business"
          autocomplete="organization"
          data-ps-name
        />
      </div>

      <div class="ps__field">
        <span class="ps__label" id="ps-colour-label">Brand colour</span>
        <div class="ps__swatches" role="radiogroup" aria-labelledby="ps-colour-label">
          {swatches.map((s, i) => (
            <button
              type="button"
              class={'ps__swatch' + (i === 0 ? ' is-selected' : '')}
              style={`--sw:${s.hex}`}
              data-ps-swatch={s.hex}
              role="radio"
              aria-checked={i === 0 ? 'true' : 'false'}
              aria-label={`Brand colour ${s.id}`}
            ></button>
          ))}
          <label class="ps__custom" title="Pick a custom colour">
            <input type="color" value={defaultHex} data-ps-custom aria-label="Custom brand colour" />
            <Icon name="sparkles" sw={1.8} />
          </label>
        </div>
      </div>

      <div class="ps__field">
        <span class="ps__label" id="ps-plan-label">What are you collecting?</span>
        <div class="ps__seg" role="radiogroup" aria-labelledby="ps-plan-label">
          <button type="button" class="ps__seg-btn is-selected" data-ps-plan="invoice" role="radio" aria-checked="true">An invoice</button>
          <button type="button" class="ps__seg-btn" data-ps-plan="deposit" role="radio" aria-checked="false">A deposit</button>
          <button type="button" class="ps__seg-btn" data-ps-plan="membership" role="radio" aria-checked="false">A membership</button>
        </div>
      </div>

      <p class="ps__abnote" data-ps-abnote hidden>
        Split test — the same page, two microcopy writers. Compare the wording and pick a winner.
      </p>

      <button type="button" class="ps__share" data-ps-share hidden>
        <Icon name="globe" sw={1.8} />
        <span data-ps-share-label>Copy a Shareable Link</span>
      </button>

      <p class="ps__disclaimer" data-ps-disclaimer hidden></p>
    </div>

    <!-- Live preview (mockup-world). Second card revealed only in A/B mode. -->
    <div class="ps__preview">
      <div class="ps__cards" data-ps-cards>
        <div class="ps__card" data-ps-card>
          <span class="ps__card-label" data-ps-card-label hidden></span>
          <CheckoutPreview />
        </div>
        <div class="ps__card" data-ps-card hidden>
          <span class="ps__card-label" data-ps-card-label hidden></span>
          <CheckoutPreview />
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .ps {
    max-width: 1080px;
    margin-inline: auto;
  }

  /* ---- URL bar ---- */
  .ps__urlbar {
    margin-bottom: 2.5rem;
  }
  .ps__url-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-brand);
    margin-bottom: 0.7rem;
  }
  .ps__url-row {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
    position: relative;
    flex-wrap: wrap;
  }
  .ps__url-globe {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    color: rgba(15, 23, 42, 0.4);
    pointer-events: none;
  }
  .ps__url-globe svg { width: 18px; height: 18px; }
  .ps__url-input {
    flex: 1 1 260px;
    min-width: 0;
    font: inherit;
    font-size: 1.05rem;
    color: var(--color-primary-brand);
    background: var(--color-pure-white);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: var(--radius-input);
    padding: 0.9rem 1rem 0.9rem 2.6rem;
  }
  .ps__url-input:focus-visible {
    outline: 2px solid var(--color-primary-action);
    outline-offset: 2px;
    border-color: var(--color-primary-action);
  }
  .ps__url-row :global(.btn-primary) {
    flex: 0 0 auto;
  }
  .ps__status {
    margin: 0.7rem 0 0;
    font-size: 0.85rem;
    color: rgba(15, 23, 42, 0.55);
  }
  .ps__status.is-error { color: #b42318; }
  .ps__status.is-working { color: var(--color-primary-action); }

  /* ---- grid ---- */
  .ps__grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 2.5rem;
    align-items: center;
  }
  /* A/B mode: stack controls above two full-width cards */
  .ps.is-ab .ps__grid {
    grid-template-columns: 1fr;
    align-items: stretch;
    gap: 2rem;
  }

  /* ---- controls ---- */
  .ps__field { margin-bottom: 1.6rem; }
  .ps__label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-brand);
    margin-bottom: 0.7rem;
  }
  .ps__input {
    width: 100%;
    font: inherit;
    font-size: 1.05rem;
    color: var(--color-primary-brand);
    background: var(--color-pure-white);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: var(--radius-input);
    padding: 0.8rem 1rem;
  }
  .ps__input:focus-visible {
    outline: 2px solid var(--color-primary-action);
    outline-offset: 2px;
    border-color: var(--color-primary-action);
  }
  .ps__swatches { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .ps__swatch {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--sw);
    border: 0;
    cursor: pointer;
    box-shadow: 0 0 0 2px var(--color-pure-white), 0 0 0 2px rgba(15, 23, 42, 0.12);
    transition: transform var(--ease-snappy), box-shadow var(--ease-snappy);
  }
  .ps__swatch:hover { transform: scale(1.08); }
  .ps__swatch.is-selected {
    box-shadow: 0 0 0 3px var(--color-pure-white), 0 0 0 6px var(--sw);
  }
  .ps__swatch:focus-visible { outline: 2px solid var(--color-primary-action); outline-offset: 3px; }
  .ps__custom {
    position: relative;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    cursor: pointer;
    background: var(--color-secondary-bg);
    box-shadow: 0 0 0 2px var(--color-pure-white), 0 0 0 2px rgba(15, 23, 42, 0.12);
  }
  .ps__custom svg { width: 18px; height: 18px; color: rgba(15, 23, 42, 0.55); pointer-events: none; }
  .ps__custom input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .ps__seg {
    display: inline-flex;
    background: var(--color-secondary-bg);
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: var(--radius-button);
    padding: 4px;
    gap: 2px;
    flex-wrap: wrap;
  }
  .ps__seg-btn {
    font: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(15, 23, 42, 0.62);
    background: transparent;
    border: 0;
    border-radius: var(--radius-button);
    padding: 0.5rem 0.95rem;
    cursor: pointer;
    transition: background var(--ease-snappy), color var(--ease-snappy);
  }
  .ps__seg-btn.is-selected {
    background: var(--color-pure-white);
    color: var(--color-primary-brand);
    box-shadow: var(--shadow-sm);
  }
  .ps__seg-btn:focus-visible { outline: 2px solid var(--color-primary-action); outline-offset: 2px; }
  .ps__abnote {
    margin: 0 0 1.2rem;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-primary-action);
  }
  .ps__abnote[hidden] { display: none; }
  .ps__share {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-primary-brand);
    background: var(--color-pure-white);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: var(--radius-button);
    padding: 0.7rem 1.3rem;
    cursor: pointer;
    transition: background var(--ease-snappy), transform var(--ease-snappy);
  }
  .ps__share[hidden] { display: none; }
  .ps__share:hover { background: var(--color-secondary-bg); }
  .ps__share:active { transform: scale(0.98); }
  .ps__share svg { width: 17px; height: 17px; color: var(--color-primary-action); }
  .ps__disclaimer {
    margin: 1.2rem 0 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: rgba(15, 23, 42, 0.5);
  }
  .ps__disclaimer[hidden] { display: none; }

  /* ---- preview cards ---- */
  .ps__preview { display: block; }
  .ps__cards {
    display: grid;
    grid-template-columns: minmax(0, 420px);
    justify-content: center;
    gap: 1.5rem 1.75rem;
  }
  .ps.is-ab .ps__cards {
    grid-template-columns: repeat(2, minmax(0, 420px));
    justify-content: center;
    align-items: start;
  }
  .ps__card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-width: 0;
  }
  .ps__card[hidden] { display: none; }
  .ps__card-label {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-brand);
    background: var(--color-secondary-bg);
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: var(--radius-button);
    padding: 0.3rem 0.75rem;
  }
  .ps__card-label[hidden] { display: none; }
  .ps__card-label.is-empty { color: rgba(15, 23, 42, 0.45); }

  @media (max-width: 860px) {
    .ps__grid { grid-template-columns: 1fr; gap: 2rem; }
    .ps__controls { order: 2; }
    .ps__preview { order: 1; }
  }
  @media (max-width: 760px) {
    .ps.is-ab .ps__cards { grid-template-columns: minmax(0, 420px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ps__swatch, .ps__share { transition: none; }
  }
</style>

<script>
  import { readable, initials, slugify, SCENARIOS } from '../../scripts/brandReskin.mjs';

  const FONT_LINK_ID = 'ps-brand-font';

  function normaliseUrl(raw) {
    let v = String(raw || '').trim();
    if (!v) return null;
    if (!/^https?:\/\//i.test(v)) v = 'https://' + v;
    try {
      const u = new URL(v);
      if (u.protocol !== 'http:' && u.protocol !== 'https:') return null;
      if (!u.hostname.includes('.')) return null;
      return u;
    } catch {
      return null;
    }
  }

  const registrableDomain = (hostname) => hostname.replace(/^www\./i, '');

  // Best-effort web-font load. If the family isn't on Google Fonts the link
  // simply 404s and the CSS fallback renders — never blocks the preview.
  function loadBrandFont(family) {
    const existing = document.getElementById(FONT_LINK_ID);
    if (existing) existing.remove();
    if (!family) return;
    const link = document.createElement('link');
    link.id = FONT_LINK_ID;
    link.rel = 'stylesheet';
    link.href =
      'https://fonts.googleapis.com/css2?family=' +
      encodeURIComponent(family).replace(/%20/g, '+') +
      ':wght@400;600;700&display=swap';
    document.head.appendChild(link);
  }

  // Friendly provider label from a model id.
  function providerLabel(who, model) {
    return (who === 'openai' ? 'OpenAI' : 'Claude') + ' · ' + (model || who);
  }

  document.querySelectorAll('[data-ps]').forEach((root) => {
    if (root.dataset.psBound) return;
    root.dataset.psBound = '1';

    const defName = root.dataset.defaultName;
    const defColour = root.dataset.defaultColour;
    const endpoint = root.dataset.endpoint || '';

    const form = root.querySelector('[data-ps-form]');
    const urlInput = root.querySelector('[data-ps-url]');
    const generateBtn = root.querySelector('[data-ps-generate]');
    const statusEl = root.querySelector('[data-ps-status]');
    const nameInput = root.querySelector('[data-ps-name]');
    const swatchEls = root.querySelectorAll('[data-ps-swatch]');
    const customInput = root.querySelector('[data-ps-custom]');
    const planBtns = root.querySelectorAll('[data-ps-plan]');
    const shareBtn = root.querySelector('[data-ps-share]');
    const shareLabel = root.querySelector('[data-ps-share-label]');
    const disclaimerEl = root.querySelector('[data-ps-disclaimer]');
    const abNote = root.querySelector('[data-ps-abnote]');

    // Two preview cards; the second is revealed only in A/B mode.
    const cardEls = Array.from(root.querySelectorAll('[data-ps-card]'));
    const checkouts = cardEls.map((c) => c.querySelector('[data-checkout]'));
    const cardLabels = cardEls.map((c) => c.querySelector('[data-ps-card-label]'));

    // Button renders "<text node>Generate Preview</text><svg icon/>" — toggle the
    // text node so the trailing icon survives the loading state.
    const btnTextNode = generateBtn ? generateBtn.childNodes[0] : null;
    const genLabel = btnTextNode ? btnTextNode.textContent : 'Generate Preview';
    const setBtnLabel = (t) => { if (btnTextNode) btnTextNode.textContent = t; };

    const state = {
      name: defName,
      colour: defColour,
      plan: 'invoice',
      domain: '',
      logoUrl: '',
      scenarioTouched: false,
      ab: { active: false, primary: null, secondary: null },
    };

    const setStatus = (msg, kind) => {
      if (!statusEl) return;
      statusEl.textContent = msg;
      statusEl.classList.toggle('is-error', kind === 'error');
      statusEl.classList.toggle('is-working', kind === 'working');
    };

    function checkoutParts(checkout) {
      return {
        mono: checkout.querySelector('[data-bs-mono]'),
        logo: checkout.querySelector('[data-bs-logo]'),
        brand: checkout.querySelector('[data-bs-brand]'),
        display: checkout.querySelector('[data-bs-display]'),
        headline: checkout.querySelector('[data-bs-headline]'),
        subcopy: checkout.querySelector('[data-bs-subcopy]'),
        amount: checkout.querySelector('[data-bs-amount]'),
        pay: checkout.querySelector('[data-bs-paylabel]'),
        url: checkout.querySelector('.mok__url'),
      };
    }

    function applyColour(hex) {
      state.colour = hex;
      root.style.setProperty('--bs-accent', hex);
      root.style.setProperty('--bs-on-accent', readable(hex));
      swatchEls.forEach((s) => {
        const on = s.dataset.psSwatch.toLowerCase() === hex.toLowerCase();
        s.classList.toggle('is-selected', on);
        s.setAttribute('aria-checked', on ? 'true' : 'false');
      });
      if (customInput && /^#[0-9a-fA-F]{6}$/.test(hex)) customInput.value = hex;
    }

    // Brand fields shared by every visible card (logo, mono, name, amount, url).
    function paintShared() {
      const name = state.name.trim() || defName;
      const plan = SCENARIOS[state.plan];
      const host = state.domain || slugify(state.name) + '.co.uk';
      checkouts.forEach((checkout) => {
        if (!checkout) return;
        const p = checkoutParts(checkout);
        if (p.mono) p.mono.textContent = initials(state.name);
        if (p.display) p.display.textContent = name;
        if (p.amount) p.amount.textContent = plan.amount;
        if (p.pay) p.pay.textContent = plan.pay(plan.amount);
        if (p.url) {
          const icon = p.url.querySelector('svg');
          p.url.textContent = 'pay.' + host + '/' + plan.path;
          if (icon) p.url.prepend(icon);
        }
        if (p.logo && p.brand) {
          if (state.logoUrl) {
            p.logo.alt = name + ' logo';
            if (p.logo.getAttribute('src') !== state.logoUrl) {
              p.logo.onload = () => { p.logo.hidden = false; p.brand.classList.add('has-logo'); };
              p.logo.onerror = () => { p.logo.hidden = true; p.brand.classList.remove('has-logo'); };
              p.logo.src = state.logoUrl;
            } else if (p.logo.complete && p.logo.naturalWidth) {
              p.logo.hidden = false;
              p.brand.classList.add('has-logo');
            }
          } else {
            p.logo.hidden = true;
            p.brand.classList.remove('has-logo');
          }
        }
      });
    }

    // Per-card microcopy (the only thing that differs between A and B).
    function paintCopy(checkout, copy) {
      if (!checkout) return;
      const p = checkoutParts(checkout);
      const plan = SCENARIOS[state.plan];
      const headline = copy && copy.headline && !state.scenarioTouched ? copy.headline : plan.headline;
      if (p.headline) p.headline.textContent = headline;
      if (p.subcopy) {
        if (copy && copy.subcopy) {
          p.subcopy.textContent = copy.subcopy;
          p.subcopy.hidden = false;
        } else {
          p.subcopy.hidden = true;
        }
      }
    }

    function render() {
      paintShared();
      paintCopy(checkouts[0], state.ab.primary);
      if (state.ab.active) paintCopy(checkouts[1], state.ab.secondary);
    }

    function setCardLabel(i, text, hasCopy) {
      const el = cardLabels[i];
      if (!el) return;
      if (!text) { el.hidden = true; return; }
      el.textContent = hasCopy ? text : text + ' — no copy returned';
      el.classList.toggle('is-empty', !hasCopy);
      el.hidden = false;
    }

    // ---- manual controls (always live; the fallback if extraction fails) ----
    nameInput.addEventListener('input', () => { state.name = nameInput.value; render(); });
    swatchEls.forEach((s) => s.addEventListener('click', () => applyColour(s.dataset.psSwatch)));
    if (customInput) customInput.addEventListener('input', () => applyColour(customInput.value));
    planBtns.forEach((b) =>
      b.addEventListener('click', () => {
        state.plan = b.dataset.psPlan;
        state.scenarioTouched = true; // choosing a scenario specialises the headline for both cards
        planBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('is-selected', on);
          x.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        render();
      })
    );

    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        const link = location.origin + location.pathname + '?url=' + encodeURIComponent(state.domain);
        try {
          await navigator.clipboard.writeText(link);
          if (shareLabel) shareLabel.textContent = 'Link Copied';
        } catch {
          if (shareLabel) shareLabel.textContent = 'Copy Failed';
        }
        setTimeout(() => { if (shareLabel) shareLabel.textContent = 'Copy a Shareable Link'; }, 2200);
      });
    }

    // ---- apply a fetched brand profile ----
    function applyProfile(p) {
      if (p.name) { state.name = p.name; nameInput.value = p.name.slice(0, 32); }
      if (p.colors && /^#[0-9a-fA-F]{6}$/.test(p.colors.primary || '')) applyColour(p.colors.primary);
      state.logoUrl = p.logoUrl || '';
      loadBrandFont(p.font || '');
      if (p.font) root.style.setProperty('--bs-font', `'${p.font}', system-ui, -apple-system, sans-serif`);
      else root.style.removeProperty('--bs-font');
      state.scenarioTouched = false;

      if (p.copyAB) {
        // A/B split test — two cards, one per microcopy writer.
        const models = p.copyAB.models || {};
        state.ab = { active: true, primary: p.copyAB.anthropic || null, secondary: p.copyAB.openai || null };
        setCardLabel(0, providerLabel('anthropic', models.anthropic), !!p.copyAB.anthropic);
        setCardLabel(1, providerLabel('openai', models.openai), !!p.copyAB.openai);
        if (cardEls[1]) cardEls[1].hidden = false;
        root.classList.add('is-ab');
        if (abNote) abNote.hidden = false;
      } else {
        // Single provider — one card, no labels.
        state.ab = { active: false, primary: p.copy || null, secondary: null };
        setCardLabel(0, '', false);
        if (cardEls[1]) cardEls[1].hidden = true;
        root.classList.remove('is-ab');
        if (abNote) abNote.hidden = true;
      }

      render();

      if (disclaimerEl) {
        const who = p.name || 'this business';
        disclaimerEl.textContent =
          'Illustrative preview — a sketch generated from your public branding, ' +
          'not affiliated with or endorsed by ' + who + '. No real payments are taken.';
        disclaimerEl.hidden = false;
      }
      if (shareBtn) shareBtn.hidden = !state.domain;
    }

    // ---- generate from a URL ----
    let inFlight = false;
    async function generate(rawUrl) {
      const u = normaliseUrl(rawUrl);
      if (!u) {
        setStatus('Enter a valid website address, e.g. yourbusiness.co.uk', 'error');
        urlInput.focus();
        return;
      }
      state.domain = registrableDomain(u.hostname);

      if (!endpoint) {
        setStatus("Live previews aren't switched on yet — adjust the controls below to sketch by hand.", 'error');
        return;
      }

      inFlight = true;
      if (generateBtn) generateBtn.disabled = true;
      setBtnLabel('Reading your site…');
      setStatus('Reading ' + state.domain + '…', 'working');

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ url: u.href }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data || data.error) {
          throw new Error((data && data.error) || 'extract-failed');
        }
        applyProfile(data);
        const who = data.name || state.domain;
        setStatus(
          data.copyAB
            ? "Two payment pages for " + who + ", same brand — compare the microcopy and tweak below."
            : "Here's a sketch of " + who + " in your brand. Tweak the colour or scenario below.",
          null,
        );
      } catch (err) {
        // Graceful fallback to manual entry — no dead end.
        state.domain = '';
        setStatus("We couldn't read that site automatically. No problem — set your name, colour and scenario by hand below.", 'error');
      } finally {
        inFlight = false;
        if (generateBtn) generateBtn.disabled = false;
        setBtnLabel(genLabel);
      }
    }

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!inFlight) generate(urlInput.value);
      });
    }

    // ---- hydrate from a shared ?url= link ----
    const params = new URLSearchParams(location.search);
    const sharedUrl = params.get('url');
    applyColour(defColour);
    render();
    if (sharedUrl) {
      urlInput.value = sharedUrl;
      generate(sharedUrl);
    }
  });
</script>
