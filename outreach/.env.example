# Copy to outreach/.env and fill in. NEVER commit the real .env (it is gitignored).
# Supabase project: xqpbcoldcqfxfwhcqlcy

# Privileged Postgres connection (psycopg), server-side only.
# Use the SESSION POOLER string (Dashboard -> Connect -> Session pooler) — IPv4, DDL-capable.
# The direct host db.<ref>.supabase.co is IPv6-only and may not resolve.
DATABASE_URL=postgresql://postgres.<ref>:YOUR_DB_PASSWORD@aws-1-<region>.pooler.supabase.com:5432/postgres

# Pipeline schema (its own; never touches the website's public tables).
DB_SCHEMA=outreach
# Website inbound-enquiry source to suppress against (public schema): leads -> enquiries after repoint.
ENQUIRY_SOURCE_TABLE=leads

# Phase B — Companies House Advanced Search (free): developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=
CH_MAX_REQUESTS_PER_RUN=50

# Phase D — MillionVerifier (paid; tiny samples only during build)
MILLIONVERIFIER_API_KEY=
MV_MAX_PER_RUN=20

# Phase D — website discovery: inline (default, loop agent) | firecrawl | brave
# Firecrawl free = 1,000 credits/mo (~500 searches), no card. Brave = $5/1k, card required.
WEBSITE_RESOLVER=inline
FIRECRAWL_API_KEY=
BRAVE_SEARCH_API_KEY=
SEARCH_MAX_REQUESTS_PER_RUN=50

# LLM provider: inline (default) | api (later, unattended)
LLM_PROVIDER=inline

# Phase G — Gmail API send (dry-run only until gate G-SEND). Google Workspace secondary
# domain, never @settlepay.uk. Generate the refresh token once: python -m outreach auth-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=        # durable credential — never commit or log
GMAIL_SENDER=               # e.g. finlay@getsettlepay.uk
# Google tolerates a higher cold limit (~18-22/inbox/day) than M365 — keep low for now.
PER_INBOX_DAILY_CAP=5
KILL_SWITCH=          # set truthy to block ALL sends (kill switch)

# G_SEND — human-only live-send gate. Leave UNSET. The loop must never set it.
