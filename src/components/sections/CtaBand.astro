---
import Button from '../Button.astro';
---
<section class="cta-section" id="enquire" data-screen-label="CTA band">
  <div class="container">
    <div class="cta-section__inner">
      <h2 class="cta-section__title">Ready to Stop Chasing Bank Transfers?</h2>
      <p class="cta-section__text">
        Book a free, no-obligation consultation. We'll review your current payment workflow and show
        you exactly how a bespoke checkout page, with payments processed by an FCA-regulated processor, can eliminate the
        admin.
      </p>
      <div class="cta-section__actions">
        <Button variant="primary" size="large" icon="arrow" enquire>Book a Free Consultation</Button>
        <Button variant="secondary" onDark href="/work/">See Our Work</Button>
      </div>
    </div>
  </div>
</section>
