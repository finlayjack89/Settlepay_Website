---
/* Eyebrow + title (with optional blue highlight word) + subtitle.
   Centred by default; `align="left"` suits sections whose content runs
   header-left / content-right. */
const { eyebrow, sentence = false, title, blue, titleAfter = '', subtitle, align = 'center' } = Astro.props;
---
<div class={'value-prop__header' + (align === 'left' ? ' value-prop__header--left' : '')}>
  <div class={'section-badge' + (sentence ? ' section-badge--sentence' : '')}>{eyebrow}</div>
  <h2 class="section-title">{title}{blue && <span>{blue}</span>}{titleAfter}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</div>
