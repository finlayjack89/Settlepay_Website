  .mvp__ghostbtn {
    margin-top: 1rem;
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--mv-line);
    border-radius: 6px;
    background: transparent;
    font-family: var(--mv-font);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--mv-ink);
    cursor: pointer;
    transition: border-color var(--ease-snappy), background var(--ease-snappy);
  }
  .mvp__ghostbtn:hover {
    border-color: var(--mv-copper);
    background: rgba(184, 115, 51, 0.07);
  }
  .mvp__ghostbtn:focus-visible {
