# Secrets for the `brand-preview` Edge Function (the /preview/ "see your payment
# page" tool). Copy to `.env` (gitignored) and set with:
#   supabase secrets set --env-file supabase/functions/brand-preview/.env
#
# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by
# Supabase at runtime — do NOT set them here.

# Brandfetch Brand API key (https://developers.brandfetch.com → Brand API).
# REQUIRED — without it the /preview/ tool degrades to manual entry.
BRANDFETCH_API_KEY=

# Firecrawl key (https://firecrawl.dev) for the homepage screenshot + copy
# excerpt shown to the design models (1 credit per generation). OPTIONAL —
# omit and the models work from Brandfetch images alone.
FIRECRAWL_API_KEY=

# --- Design-brief model split test -------------------------------------------
# DESIGN_PROVIDERS: comma list of registry keys (see providers.ts):
#   haiku   Claude Haiku 4.5   (claude-haiku-4-5)
#   sonnet  Claude Sonnet 5    (claude-sonnet-5; override with SONNET_MODEL)
#   luna    GPT-5.6 Luna       (gpt-5.6-luna)
#   terra   GPT-5.6 Terra      (gpt-5.6-terra)
# ONE key = production mode (cache enabled). Several = split test: every leg is
# called per request, all briefs returned, cache bypassed. Each request in
# 4-leg mode costs ~5-6p across providers — keep the rate limits on.
DESIGN_PROVIDERS=haiku

# Anthropic API key for the Claude legs (https://console.anthropic.com).
# Register spend in cost tracking — the function logs per-leg token usage to
# stdout as "brand-preview design usage".
ANTHROPIC_API_KEY=
SONNET_MODEL=claude-sonnet-5

# OpenAI API key for the GPT legs (https://platform.openai.com). The account
# must have billing/credit or calls return insufficient_quota.
OPENAI_API_KEY=
# Reasoning depth for the GPT-5.6 legs (low|medium|high). Low is plenty for a
# design brief and keeps latency/cost down.
OPENAI_REASONING_EFFORT=low

# Lock CORS to the live site in production (use * only while testing).
ALLOWED_ORIGIN=https://settlepay.uk

# Abuse + cost guards (defaults baked in: 5/min in split-test mode, 10/min in
# production mode, 60/day either way).
RATE_LIMIT_PER_MIN=
RATE_LIMIT_PER_DAY=60
CACHE_TTL_HOURS=168
