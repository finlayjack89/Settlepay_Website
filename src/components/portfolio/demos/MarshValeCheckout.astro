  @media (max-width: 480px) {
    .mvp__masthead,
    .mvp__pay { padding-inline: 1rem; }
    .mvp__invoice,
    .mvp__panel { margin-inline: 1rem; }
    .mvp__masthead-ref { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mvp * {
      transition: none !important;
      animation: none !important;
    }
    .mvp__paybtn:active:not(:disabled) { transform: none; }
  }
</style>

<script>
  /* Marsh & Vale invoice demo — hybrid. The mock card flow runs by default;
     when the root carries data-mv-stripe-key (set at build time from a
     pk_test_… publishable key) the mock fields are gone from the markup and a
     real Stripe Payment Element in test mode takes their place. Stripe.js is
     lazy-loaded from js.stripe.com (Stripe requires loading from their domain)
     on first interaction or when the demo nears the viewport. No secret key is
     ever referenced client-side; confirmation goes through the optional
     endpoint in data-mv-stripe-endpoint (see serverless/stripe-demo/). */

  const SUCCESS_CARD = '4242424242424242';
  const DECLINE_CARD = '4000000000000002';
  const PROCESS_DELAY_MS = 900;
  const AMOUNT_LABEL = '£386.40';
  const INVOICE_REF = 'INV-2147';

  /* Real test mode (Stripe) ------------------------------------------------ */
  const AMOUNT_MINOR = 38640; // £386.40 in pence — the Worker enforces this server-side too
  const CURRENCY = 'gbp';
  const STRIPE_JS_SRC = 'https://js.stripe.com/v3/';
  const GENERIC_PAYMENT_ERROR =
    'Something went wrong processing the payment. No charge has been made — please try again.';

  /* Appearance API — match the Marsh & Vale brand world (4-8px corners,
     copper accent, cream paper), not SettlePay's UI. */
  const STRIPE_APPEARANCE = {
    theme: 'stripe',
    variables: {
      fontFamily: "'Helvetica Neue', Helvetica, Arial, system-ui, sans-serif",
      colorPrimary: '#B87333',
      colorBackground: '#FFFDF8',
      colorText: '#1B2B22',
      colorTextSecondary: 'rgba(27, 43, 34, 0.62)',
      colorTextPlaceholder: 'rgba(27, 43, 34, 0.35)',
      colorDanger: '#DC2626',
      borderRadius: '6px',
      fontSizeBase: '15px',
      focusOutline: 'none',
      focusBoxShadow: '0 0 0 3px rgba(184, 115, 51, 0.18)',
    },
    rules: {
      '.Input': { border: '1px solid rgba(27, 43, 34, 0.14)' },
      '.Input:focus': { borderColor: '#B87333' },
      '.Label': {
        textTransform: 'uppercase',
        fontSize: '11px',
        fontWeight: '700',
        letterSpacing: '0.1em',
        color: 'rgba(27, 43, 34, 0.62)',
      },
      '.Tab': { borderRadius: '6px' },
      '.Tab--selected': { borderColor: '#B87333' },
    },
  };

  let stripeJsPromise = null;

  function loadStripeJs() {
    if (window.Stripe) return Promise.resolve(window.Stripe);
    if (!stripeJsPromise) {
      stripeJsPromise = new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = STRIPE_JS_SRC;
        script.async = true;
        script.onload = () => resolve(window.Stripe);
        script.onerror = () => {
          stripeJsPromise = null;
          script.remove();
          reject(new Error('The secure card form could not be loaded. Check your connection and try again.'));
        };
        document.head.appendChild(script);
      });
    }
    return stripeJsPromise;
  }

  let uidCounter = 0;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  function digitsOnly(value) {
    return value.replace(/\D/g, '');
  }

  function detectBrand(digits) {
    if (/^3/.test(digits)) return 'amex';
    if (/^4/.test(digits)) return 'visa';
    if (/^5/.test(digits)) return 'mastercard';
    return null;
  }

  function maxDigitsFor(brand) {
    return brand === 'amex' ? 15 : 16;
  }

  function groupCardDigits(digits, brand) {
    const groups = brand === 'amex' ? [4, 6, 5] : [4, 4, 4, 4];
    const parts = [];
    let i = 0;
    for (const size of groups) {
      if (i >= digits.length) break;
      parts.push(digits.slice(i, i + size));
      i += size;
    }
    return parts.join(' ');
  }

  function formatExpiry(raw) {
    let digits = digitsOnly(raw).slice(0, 4);
    if (digits.length >= 1 && Number(digits[0]) > 1) digits = ('0' + digits).slice(0, 4);
    if (digits.length <= 2) return digits;
    return digits.slice(0, 2) + ' / ' + digits.slice(2);
  }

  function expiryIsValid(raw) {
    const digits = digitsOnly(raw);
    if (digits.length !== 4) return false;
    const month = Number(digits.slice(0, 2));
    if (month < 1 || month > 12) return false;
    const year = 2000 + Number(digits.slice(2));
    const now = new Date();
    return year > now.getFullYear() || (year === now.getFullYear() && month >= now.getMonth() + 1);
  }

  function restoreCaret(input, digitsBeforeCaret) {
    let seen = 0;
    let pos = input.value.length;
    for (let i = 0; i < input.value.length; i += 1) {
      if (seen === digitsBeforeCaret) { pos = i; break; }
      if (/\d/.test(input.value[i])) seen += 1;
    }
    if (seen < digitsBeforeCaret) pos = input.value.length;
    input.setSelectionRange(pos, pos);
  }

  function reformatInput(input, formatter) {
    const caret = input.selectionStart ?? input.value.length;
    const digitsBeforeCaret = digitsOnly(input.value.slice(0, caret)).length;
    input.value = formatter(input.value);
    restoreCaret(input, digitsBeforeCaret);
  }

  function setError(ctx, fieldName, message) {
    const field = ctx.fields[fieldName];
    field.input.setAttribute('aria-invalid', 'true');
    field.errorText.textContent = message;
    field.error.hidden = false;
  }

  function clearError(ctx, fieldName) {
    const field = ctx.fields[fieldName];
    field.input.removeAttribute('aria-invalid');
    field.errorText.textContent = '';
    field.error.hidden = true;
  }

  function validateName(ctx, value) {
    if (value.trim().length < 2) return 'Enter the name on the card.';
    return null;
  }

  function validateNumber(ctx, value) {
    const digits = digitsOnly(value);
    if (!digits) return 'Enter your card number.';
    const brand = detectBrand(digits);
    if (digits.length !== maxDigitsFor(brand)) return 'Enter a valid card number.';
    return null;
  }

  function validateExpiry(ctx, value) {
    const digits = digitsOnly(value);
    if (!digits) return 'Enter the expiry date.';
    if (digits.length !== 4 || Number(digits.slice(0, 2)) < 1 || Number(digits.slice(0, 2)) > 12) {
      return 'Enter a valid date as MM / YY.';
    }
    if (!expiryIsValid(value)) return 'This card has expired.';
    return null;
  }

  function validateCvc(ctx, value) {
    const digits = digitsOnly(value);
    if (digits.length < 3 || digits.length > 4) return 'Enter the 3 or 4 digit code.';
    return null;
  }

  const VALIDATORS = {
    name: validateName,
    number: validateNumber,
    expiry: validateExpiry,
    cvc: validateCvc,
  };

  function validateField(ctx, fieldName) {
    const message = VALIDATORS[fieldName](ctx, ctx.fields[fieldName].input.value);
    if (message) setError(ctx, fieldName, message);
    else clearError(ctx, fieldName);
    return !message;
  }

  function validateAll(ctx) {
    let firstInvalid = null;
    for (const name of Object.keys(ctx.fields)) {
      if (!validateField(ctx, name) && !firstInvalid) firstInvalid = ctx.fields[name].input;
    }
    if (firstInvalid) firstInvalid.focus();
    return !firstInvalid;
  }

  function updateBrandMarks(ctx) {
    const brand = detectBrand(digitsOnly(ctx.fields.number.input.value));
    if (brand) ctx.brands.setAttribute('data-active', '');
    else ctx.brands.removeAttribute('data-active');
    for (const mark of ctx.brandMarks) {
      mark.classList.toggle('is-match', mark.getAttribute('data-mv-brand') === brand);
    }
  }

  function announce(ctx, message) {
    ctx.status.textContent = message;
  }

  function setProcessing(ctx, processing) {
    ctx.submit.disabled = processing;
    ctx.submitLabel.hidden = processing;
    ctx.submitBusy.hidden = !processing;
  }

  /* Seam for the Stripe layer: replace this with a real test-mode confirm call
     that resolves to 'success' | 'declined'. */
  function fakeProcessPayment(cardDigits) {
    const outcome = cardDigits === DECLINE_CARD ? 'declined' : 'success';
    const delay = reducedMotion.matches ? 0 : PROCESS_DELAY_MS;
    return new Promise((resolve) => setTimeout(() => resolve(outcome), delay));
  }

  function showSuccess(ctx, opts) {
    ctx.pay.hidden = true;
    ctx.successPanel.hidden = false;
    ctx.chipDue.hidden = true;
    ctx.chipPaid.hidden = false;
    if (ctx.validatedNote) ctx.validatedNote.hidden = !(opts && opts.validatedOnly);
    if (ctx.successTitle) {
      ctx.successTitle.textContent =
        opts && opts.validatedOnly ? 'Card Details Validated' : 'Payment Received';
    }
    if (opts && opts.validatedOnly) {
      announce(ctx, 'Card details validated by Stripe in test mode. The confirmation endpoint is not configured in this preview, so no test charge was made.');
    } else {
      announce(ctx, `Payment received. ${AMOUNT_LABEL} paid against invoice ${INVOICE_REF}. A receipt has been emailed to you.`);
    }
    ctx.resetBtn.focus();
  }

  function showDeclined(ctx, message) {
    if (ctx.declinedText) {
      ctx.declinedText.textContent = message || ctx.declinedDefaultText;
    }
    ctx.pay.hidden = true;
    ctx.declinedPanel.hidden = false;
    announce(ctx, message || 'Your card was declined. No charge has been made.');
    ctx.retryBtn.focus();
  }

  function returnToForm(ctx) {
    ctx.declinedPanel.hidden = true;
    ctx.pay.hidden = false;
    setProcessing(ctx, false);
    if (ctx.realMode) ctx.submit.focus();
    else ctx.fields.number.input.focus();
  }

  function resetDemo(ctx) {
    ctx.form.reset();
    if (ctx.realMode) {
      clearStripeError(ctx);
    } else {
      for (const name of Object.keys(ctx.fields)) clearError(ctx, name);
      updateBrandMarks(ctx);
    }
    setProcessing(ctx, false);
    ctx.successPanel.hidden = true;
    ctx.declinedPanel.hidden = true;
    if (ctx.validatedNote) ctx.validatedNote.hidden = true;
    ctx.walletNote.hidden = true;
    ctx.chipPaid.hidden = true;
    ctx.chipDue.hidden = false;
    ctx.pay.hidden = false;
    announce(ctx, 'Demo restarted.');
    if (ctx.realMode) ctx.submit.focus();
    else ctx.fields.name.input.focus();
  }

  async function handleSubmit(ctx, event) {
    event.preventDefault();
    if (ctx.submit.disabled) return;
    if (ctx.realMode) {
      await handleRealSubmit(ctx);
      return;
    }
    if (!validateAll(ctx)) return;
    setProcessing(ctx, true);
    announce(ctx, 'Processing payment.');
    const outcome = await fakeProcessPayment(digitsOnly(ctx.fields.number.input.value));
    if (outcome === 'declined') showDeclined(ctx);
    else showSuccess(ctx);
  }

  /* Real test-mode flow ----------------------------------------------------- */

  function showStripeError(ctx, message) {
    ctx.stripeField.errorText.textContent = message || GENERIC_PAYMENT_ERROR;
    ctx.stripeField.error.hidden = false;
    announce(ctx, message || GENERIC_PAYMENT_ERROR);
  }

  function clearStripeError(ctx) {
    if (!ctx.stripeField) return;
    ctx.stripeField.errorText.textContent = '';
    ctx.stripeField.error.hidden = true;
  }

  function ensureStripe(ctx) {
    if (!ctx.stripeReady) {
      ctx.stripeReady = loadStripeJs()
        .then((Stripe) => {
          const stripe = Stripe(ctx.stripeKey);
          const elements = stripe.elements({
            mode: 'payment',
            amount: AMOUNT_MINOR,
            currency: CURRENCY,
            appearance: STRIPE_APPEARANCE,
          });
          const payment = elements.create('payment', { layout: 'tabs' });
          payment.on('ready', () => {
            if (ctx.stripeLoadingNote) ctx.stripeLoadingNote.hidden = true;
          });
          payment.on('loaderror', (event) => {
            const message = (event && event.error && event.error.message) || null;
            if (ctx.stripeLoadingNote) {
              ctx.stripeLoadingNote.textContent =
                message || 'The secure card form could not be loaded. Check your connection and try again.';
            }
          });
          ctx.stripeMount.classList.add('is-ready');
          payment.mount(ctx.stripeMount);
          return { stripe, elements };
        })
        .catch((err) => {
          ctx.stripeReady = null;
          throw err;
        });
    }
    return ctx.stripeReady;
  }

  function armStripeLazyLoad(ctx) {
    const start = () => {
      ensureStripe(ctx).catch((err) => {
        if (ctx.stripeLoadingNote) {
          ctx.stripeLoadingNote.textContent = err.message || GENERIC_PAYMENT_ERROR;
        }
      });
    };
    ctx.root.addEventListener('pointerenter', start, { once: true });
    ctx.root.addEventListener('focusin', start, { once: true });
    ctx.root.addEventListener('touchstart', start, { once: true, passive: true });
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            start();
          }
        },
        { rootMargin: '200px' },
      );
      observer.observe(ctx.root);
    } else {
      start();
    }
  }

  function buildReturnUrl() {
    const url = new URL(window.location.href);
    url.searchParams.set('paid', '1');
    return url.toString();
  }

  function scrubReturnParams() {
    const url = new URL(window.location.href);
    for (const param of ['paid', 'redirect_status', 'payment_intent', 'payment_intent_client_secret']) {
      url.searchParams.delete(param);
    }
    window.history.replaceState(null, '', url.toString());
  }

  /* Handles arriving back on the page after a redirect-based confirmation
     (e.g. a 3D Secure flow that left the page) via return_url "?paid=1". */
  function handleRedirectReturn(ctx) {
    const params = new URLSearchParams(window.location.search);
    if (params.get('paid') !== '1') return;
    const failed = params.get('redirect_status') === 'failed';
    scrubReturnParams();
    if (failed) {
      showDeclined(ctx, 'The payment was not completed. No charge has been made — you can try again.');
    } else {
      showSuccess(ctx);
    }
  }

  async function createDemoPaymentIntent(ctx) {
    const response = await fetch(ctx.stripeEndpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount: AMOUNT_MINOR, currency: CURRENCY }),
    });
    if (!response.ok) throw new Error(GENERIC_PAYMENT_ERROR);
    const data = await response.json();
    if (!data || typeof data.clientSecret !== 'string') throw new Error(GENERIC_PAYMENT_ERROR);
    return data.clientSecret;
  }

  async function handleRealSubmit(ctx) {
    setProcessing(ctx, true);
    clearStripeError(ctx);
    announce(ctx, 'Processing payment.');
    try {
      const { stripe, elements } = await ensureStripe(ctx);
      const { error: submitError } = await elements.submit();
      if (submitError) {
        showStripeError(ctx, submitError.message);
        setProcessing(ctx, false);
        return;
      }
      if (!ctx.stripeEndpoint) {
        showSuccess(ctx, { validatedOnly: true });
        return;
      }
      const clientSecret = await createDemoPaymentIntent(ctx);
      const { error, paymentIntent } = await stripe.confirmPayment({
        elements,
        clientSecret,
        confirmParams: { return_url: buildReturnUrl() },
        redirect: 'if_required',
      });
      if (error) {
        if (error.type === 'card_error') {
          showDeclined(ctx, error.message);
        } else {
          showStripeError(ctx, error.message);
          setProcessing(ctx, false);
        }
        return;
      }
      const status = paymentIntent && paymentIntent.status;
      if (status === 'succeeded' || status === 'processing' || status === 'requires_capture') {
        showSuccess(ctx);
      } else {
        showStripeError(ctx, GENERIC_PAYMENT_ERROR);
        setProcessing(ctx, false);
      }
    } catch (err) {
      showStripeError(ctx, (err && err.message) || GENERIC_PAYMENT_ERROR);
      setProcessing(ctx, false);
    }
  }

  function collectStripeField(root, instanceId) {
    const wrap = root.querySelector('[data-mv-field="stripe"]');
    const error = wrap.querySelector('[data-mv-error]');
    const errorText = wrap.querySelector('[data-mv-error-text]');
    error.id = `mv-${instanceId}-stripe-error`;
    return { error, errorText };
  }

  function initRealMode(ctx, instanceId) {
    ctx.realMode = true;
    ctx.stripeKey = ctx.root.dataset.mvStripeKey;
    ctx.stripeEndpoint = ctx.root.dataset.mvStripeEndpoint || '';
    ctx.stripeMount = ctx.root.querySelector('[data-mv-stripe-mount]');
    ctx.stripeLoadingNote = ctx.root.querySelector('[data-mv-stripe-loading]');
    ctx.stripeField = collectStripeField(ctx.root, instanceId);
    ctx.stripeReady = null;
    handleRedirectReturn(ctx);
    armStripeLazyLoad(ctx);
  }

  function handleWalletClick(ctx) {
    ctx.walletNote.hidden = false;
    announce(ctx, 'Apple Pay and Google Pay are available on the live page. Use the card form in this demo.');
    window.clearTimeout(ctx.walletTimer);
    ctx.walletTimer = window.setTimeout(() => { ctx.walletNote.hidden = true; }, 4000);
  }

  function bindFormatting(ctx) {
    const numberInput = ctx.fields.number.input;
    numberInput.addEventListener('input', () => {
      reformatInput(numberInput, (value) => {
        const digits = digitsOnly(value);
        const brand = detectBrand(digits);
        return groupCardDigits(digits.slice(0, maxDigitsFor(brand)), brand);
      });
      updateBrandMarks(ctx);
    });

    const expiryInput = ctx.fields.expiry.input;
    expiryInput.addEventListener('input', () => reformatInput(expiryInput, formatExpiry));

    const cvcInput = ctx.fields.cvc.input;
    cvcInput.addEventListener('input', () => {
      reformatInput(cvcInput, (value) => digitsOnly(value).slice(0, 4));
    });
  }

  function bindValidation(ctx) {
    for (const name of Object.keys(ctx.fields)) {
      const { input } = ctx.fields[name];
      input.addEventListener('blur', () => {
        if (input.value.trim() !== '') validateField(ctx, name);
      });
      input.addEventListener('input', () => {
        if (input.getAttribute('aria-invalid') === 'true') validateField(ctx, name);
      });
    }
  }

  function collectField(root, name, instanceId) {
    const wrap = root.querySelector(`[data-mv-field="${name}"]`);
    const input = wrap.querySelector('[data-mv-input]');
    const error = wrap.querySelector('[data-mv-error]');
    const errorText = wrap.querySelector('[data-mv-error-text]');
    const errorId = `mv-${instanceId}-${name}-error`;
    error.id = errorId;
    input.setAttribute('aria-describedby', errorId);
    return { input, error, errorText };
  }

  function initDemo(root) {
    if (root.dataset.mvBound) return;
    root.dataset.mvBound = 'true';
    const instanceId = ++uidCounter;

    const ctx = {
      root,
      realMode: false,
      pay: root.querySelector('[data-mv-pay]'),
      form: root.querySelector('[data-mv-form]'),
      submit: root.querySelector('[data-mv-submit]'),
      submitLabel: root.querySelector('.mvp__paybtn-label'),
      submitBusy: root.querySelector('[data-mv-busy]'),
      successPanel: root.querySelector('[data-mv-success]'),
      successTitle: root.querySelector('[data-mv-success-title]'),
      declinedPanel: root.querySelector('[data-mv-declined]'),
      resetBtn: root.querySelector('[data-mv-reset]'),
      retryBtn: root.querySelector('[data-mv-retry]'),
      status: root.querySelector('[data-mv-status]'),
      walletNote: root.querySelector('[data-mv-wallet-note]'),
      chipDue: root.querySelector('[data-mv-chip-due]'),
      chipPaid: root.querySelector('[data-mv-chip-paid]'),
      validatedNote: root.querySelector('[data-mv-validated]'),
      walletTimer: 0,
    };
    ctx.declinedText = ctx.declinedPanel.querySelector('.mvp__panel-text');
    ctx.declinedDefaultText = ctx.declinedText ? ctx.declinedText.textContent : '';

    if (root.dataset.mvStripeKey) {
      initRealMode(ctx, instanceId);
    } else {
      ctx.brands = root.querySelector('[data-mv-brands]');
      ctx.brandMarks = Array.from(root.querySelectorAll('[data-mv-brand]'));
      ctx.fields = {
        name: collectField(root, 'name', instanceId),
        number: collectField(root, 'number', instanceId),
        expiry: collectField(root, 'expiry', instanceId),
        cvc: collectField(root, 'cvc', instanceId),
      };
      root.querySelector('[data-mv-field="number"]').classList.add('mvp__field--number-padded');
      bindFormatting(ctx);
      bindValidation(ctx);
    }

    ctx.form.addEventListener('submit', (event) => handleSubmit(ctx, event));
    ctx.resetBtn.addEventListener('click', () => resetDemo(ctx));
    ctx.retryBtn.addEventListener('click', () => returnToForm(ctx));
    for (const wallet of root.querySelectorAll('[data-mv-wallet]')) {
      wallet.addEventListener('click', () => handleWalletClick(ctx));
    }
  }

  function initMarshValeDemos() {
    document.querySelectorAll('[data-mv-demo]').forEach(initDemo);
  }

  initMarshValeDemos();
</script>
