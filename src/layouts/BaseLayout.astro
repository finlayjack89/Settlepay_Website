---
/**
 * BaseLayout — the page shell shared by every route.
 * Loads the design-system CSS, renders the SEO head, nav, footer, the enquiry
 * modal and all client scripts; pages supply their content via the slot.
 */
import '../styles/styles.css';
import '../styles/kit-extras.css';
import '../styles/site.css';

import { SITE } from '../data/site.mjs';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EnquireModal from '../components/EnquireModal.astro';
import StickyCta from '../components/StickyCta.astro';
import SiteScripts from '../components/SiteScripts.astro';

const isHome = Astro.url.pathname === '/';
// Mobile sticky CTA: homepage + the persuasion pages. Deliberately absent from
// /book/ and /manage/ (they ARE the funnel), legal pages, and the preview tool
// (it has its own post-generation CTA).
const showStickyCta =
  isHome || /^\/(work|about|faq)(\/|$)/.test(Astro.url.pathname);

const {
  title,
  description,
  image,
  imageAlt,
  ogTitle,
  ogDescription,
  keywords,
  type = 'website',
  noindex = false,
  canonical,
  jsonLd = [],
  mainClass = '',
} = Astro.props;
---
<!doctype html>
<html lang="en-GB">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      keywords={keywords}
      type={type}
      noindex={noindex}
      canonical={canonical}
      jsonLd={jsonLd}
    />
  </head>
  <body data-events={SITE.eventsEndpoint}>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Nav />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <!-- StickyCta sits BEFORE the footer on purpose: its sticky anchor's
         static position must have real content below it, so the bleed
         hanging under the anchor tucks beneath the footer instead of
         extending the page's scroll range past it. It docks (and is
         IO-suppressed) exactly as the footer scrolls in. -->
    {showStickyCta && <StickyCta />}
    <Footer />
    <EnquireModal />
    <SiteScripts />
  </body>
</html>
