---
/**
 * TrustBar — slim one-line proof strip directly under the hero (styles in
 * kit-extras.css .trust-strip). Items come from SITE.trustPoints; the green
 * pill names the one real live client.
 */
import Icon from '../Icon.astro';
import { SITE } from '../../data/site.mjs';

const trust = SITE.trustPoints;
---
<section class="trust-strip" data-screen-label="Trust strip">
  <div class="container">
    <div class="trust-strip__row">
      {trust.map((b) => (
        <div class="trust-strip__item">
          <Icon name={b.icon} sw={1.75} />
          {b.title}
        </div>
      ))}
      <a class="trust-strip__live" href="/work/lockdales-auctioneers/">Live with Lockdales Auctioneers</a>
    </div>
  </div>
</section>
