---
/* Generic interactive workflow theatre, driven by caseStudy.theatre data.
   Two or three synchronised panes (their system / customer touch / SettlePay
   ops) step through one item end to end, with play/step controls and captions.
   The bespoke Marsh & Vale flagship (MarshValeFlow.astro) stays separate; this
   brings the other case studies up to playable-workflow parity from data alone.

   Entirely simulated: fictional rows, no real systems. User-initiated only —
   never autoplays on scroll — and honours prefers-reduced-motion. The full
   step data is embedded as JSON; the client script rebuilds rows on each step,
   with step 0 server-rendered for a sensible no-JS state. */
import Icon from '../Icon.astro';

const { theatre, accent = '#0F172A' } = Astro.props;
const s0 = theatre.steps[0];

function rowsFor(paneKey, step) {
  return step.rows && step.rows[paneKey] ? step.rows[paneKey] : [];
}
---
<div
  class="ct"
  data-theatre
  style={`--ct-accent:${accent}`}
>
  <div class={'ct__stage ct__stage--' + theatre.panes.length}>
    {theatre.panes.map((p) => (
      <section class={'ct-pane' + (s0.active === p.key ? ' is-active' : '')} data-pane={p.key} aria-label={p.label + ' (simulated)'}>
        <header class="ct-pane__head">
          <span class="ct-pane__title">{p.label}</span>
          {p.sync ? (
            <span class="ct-pane__chip"><Icon name="refresh" sw={2.2} />{p.sync}</span>
          ) : (
            <span class="ct-pane__chip ct-pane__chip--sim">{p.tag ?? 'Simulated'}</span>
          )}
        </header>
        <div class="ct-pane__rows" data-rows={p.key}>
          {rowsFor(p.key, s0).map((r) => (
            <div class="ct-row">
              <span class="ct-row__dot" style={`background:${accent}`} aria-hidden="true"></span>
              <div class="ct-row__main">
                <span class="ct-row__ref">{r.ref}</span>
                <span class="ct-row__who">{r.who}</span>
                <span class="ct-row__sub">{r.sub}</span>
              </div>
              <span class={'ops-status ops-status--' + (r.status ?? 'due')}>{r.label}</span>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <p class="ct__caption" aria-live="polite" data-ct-caption>{theatre.intro}</p>

  <div class="ct__controls">
    <button class="ct__btn ct__btn--play" type="button" data-ct-play aria-pressed="false">
      <span class="ct__ic ct__ic--play"><Icon name="play" sw={1.8} /></span>
      <span class="ct__ic ct__ic--pause"><Icon name="pause" sw={2} /></span>
      <span data-ct-playlabel>Play the Flow</span>
    </button>
    <div class="ct__steps" role="group" aria-label="Steps">
      <button class="ct__btn ct__btn--nav" type="button" data-ct-prev aria-label="Previous step">
        <Icon name="chevron" sw={2.2} style="transform: rotate(90deg)" />
      </button>
      <div class="ct__dots" data-ct-dots></div>
      <button class="ct__btn ct__btn--nav" type="button" data-ct-next aria-label="Next step">
        <Icon name="chevron" sw={2.2} style="transform: rotate(-90deg)" />
      </button>
    </div>
  </div>

  <script type="application/json" data-ct-json set:html={JSON.stringify(theatre)}></script>
</div>

<script>
  const INTERVAL = 3600;

  document.querySelectorAll("[data-theatre]").forEach((root) => {
    if (root.dataset.ctBound) return;
    root.dataset.ctBound = "1";

    const data = JSON.parse(root.querySelector("[data-ct-json]").textContent);
    const accent = getComputedStyle(root).getPropertyValue("--ct-accent").trim() || "#0F172A";
    const steps = data.steps;
    const TOTAL = steps.length - 1;
    const panes = data.panes.map((p) => p.key);

    const paneEls = {};
    panes.forEach((k) => {
      paneEls[k] = {
        pane: root.querySelector(`[data-pane="${k}"]`),
        rows: root.querySelector(`[data-rows="${k}"]`),
      };
    });
    const caption = root.querySelector("[data-ct-caption]");
    const playBtn = root.querySelector("[data-ct-play]");
    const playLabel = root.querySelector("[data-ct-playlabel]");
    const prevBtn = root.querySelector("[data-ct-prev]");
    const nextBtn = root.querySelector("[data-ct-next]");
    const dotsWrap = root.querySelector("[data-ct-dots]");

    let step = 0;
    let timer = null;

    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

    function rowHtml(r) {
      return (
        '<div class="ct-row">' +
        `<span class="ct-row__dot" style="background:${accent}" aria-hidden="true"></span>` +
        '<div class="ct-row__main">' +
        `<span class="ct-row__ref">${esc(r.ref)}</span>` +
        `<span class="ct-row__who">${esc(r.who)}</span>` +
        `<span class="ct-row__sub">${esc(r.sub)}</span>` +
        "</div>" +
        `<span class="ops-status ops-status--${r.status || "due"}">${esc(r.label)}</span>` +
        "</div>"
      );
    }

    const dots = steps.map((_, i) => {
      const b = document.createElement("button");
      b.type = "button";
      b.setAttribute("aria-label", i === 0 ? "Start" : "Step " + i);
      b.addEventListener("click", () => { stop(); go(i); });
      dotsWrap.appendChild(b);
      return b;
    });

    function render() {
      const s = steps[step];
      panes.forEach((k) => {
        const rows = (s.rows && s.rows[k]) || [];
        paneEls[k].rows.innerHTML = rows.map(rowHtml).join("");
        paneEls[k].pane.classList.toggle("is-active", s.active === k);
      });
      caption.textContent = s.caption || data.intro;
      dots.forEach((d, i) => d.setAttribute("aria-current", i === step ? "true" : "false"));
      prevBtn.disabled = step === 0;
      nextBtn.disabled = step === TOTAL;
      playLabel.textContent = timer ? "Pause" : step === TOTAL ? "Replay the Flow" : "Play the Flow";
      playBtn.setAttribute("aria-pressed", timer ? "true" : "false");
    }

    function go(n) { step = Math.max(0, Math.min(TOTAL, n)); render(); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } render(); }
    function play() {
      if (step === TOTAL) go(0);
      timer = setInterval(() => { if (step >= TOTAL) { stop(); return; } go(step + 1); }, INTERVAL);
      render();
    }

    playBtn.addEventListener("click", () => (timer ? stop() : play()));
    prevBtn.addEventListener("click", () => { stop(); go(step - 1); });
    nextBtn.addEventListener("click", () => { stop(); go(step + 1); });

    render();
  });
</script>
