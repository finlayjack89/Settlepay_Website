---
import Icon from '../Icon.astro';
import Button from '../Button.astro';
import StatusChip from '../StatusChip.astro';
import ParticleField from '../ParticleField.astro';
import { SITE } from '../../data/site.mjs';

const cardMarks = ['Visa', 'Mastercard', 'Amex'];
---
<section class="hero" id="hero" data-screen-label="Hero">
  <div class="container">
    <div class="hero__content">
      <div class="hero__badge">
        <Icon name="sparkles" sw={2.5} /> For UK Small Businesses
      </div>
      <h1 class="hero__title">
        Bespoke <span>Payment Pages</span> for UK Businesses
      </h1>
      <p class="hero__subtitle">
        Still chasing bank transfers, cheques or card payments taken over the phone? We design and
        build a branded checkout page for your business and connect it to a trusted payment processor
        — so you get paid faster, look professional, and stop reconciling payments by hand.
      </p>
      <div class="hero__actions">
        <Button variant="primary" icon="arrow" enquire>{SITE.cta.primary.label}</Button>
        <Button variant="secondary" href="#integration">See How It Works</Button>
      </div>
      <p class="hero__preview-link">
        Or <a href="/preview/">paste your website address and see your own page first</a> →
      </p>
      <div class="hero__trust-note">
        <p class="hero__trust-text">
          Your checkout runs on FCA-regulated processors like{' '}
          <strong>Stripe</strong>, <strong>Adyen</strong> and <strong>Checkout.com</strong> — trusted by millions of
          businesses globally
        </p>
      </div>
    </div>

    <div class="hero__visual">
      <div class="stage-dark hero-stage" data-tilt data-tilt-max="2.5">
        {/* WebGL island: quiet drifting particles behind the mockup. */}
        <ParticleField />
        {/* Stacked translucent layers behind the checkout — dimensional depth,
            not glow (see .claude/skills/ui-ux-pro-max: Dimensional Layering). */}
        <div class="hero-stage__layers" aria-hidden="true">
          <i class="hero-stage__layer hero-stage__layer--1"></i>
          <i class="hero-stage__layer hero-stage__layer--2"></i>
        </div>
        <div class="hero-stage__mockup">
          <!-- Illustrative branded-checkout mockup (interactive method switcher) -->
          <div class="checkout-v2" data-checkout>
            <div class="checkout-v2__inner">
              <div class="checkout-v2__express">
                <button class="express-btn express-btn--apple" aria-label="Apple Pay" type="button" tabindex="-1">
                  <img src="/assets/payment/apple-logo.svg" alt="" class="express-btn__apple" /><span>Pay</span>
                </button>
                <button class="express-btn express-btn--gpay" aria-label="Google Pay" type="button" tabindex="-1">
                  <img src="/assets/payment/google-g.svg" alt="" class="express-btn__gpay" /><span>Pay</span>
                </button>
              </div>
              <div class="checkout-v2__divider"><span>OR</span></div>
              <div class="checkout-v2__header">
                <p class="checkout-v2__title">Payment</p>
                <p class="checkout-v2__subtitle">All transactions are secure and encrypted.</p>
              </div>

              <div class="checkout-v2__accordion">
                <!-- Credit card (active) -->
                <div class="checkout-v2__panel checkout-v2__panel--active">
                  <div class="checkout-v2__panel-header" role="button" tabindex="0" aria-expanded="true">
                    <div class="checkout-v2__radio"></div>
                    <span class="checkout-v2__method-name">Credit card</span>
                    <div class="checkout-v2__icons">
                      {cardMarks.map((k) => (
                        <img src={`/assets/payment/${k}.svg`} alt={k} class="checkout-v2__card-icon" />
                      ))}
                      <div class="checkout-v2__plus5">+5</div>
                    </div>
                  </div>
                  <div class="checkout-v2__panel-body">
                    <div class="checkout-v2__input-wrap">
                      <input type="text" placeholder=" " class="checkout-v2__input" value="4242 4242 4242 4242" readonly tabindex="-1" />
                      <label class="checkout-v2__floating-label">Card number</label>
                    </div>
                    <div class="checkout-v2__input-row">
                      <div class="checkout-v2__input-wrap" style="flex:1">
                        <input type="text" placeholder=" " class="checkout-v2__input" value="04 / 28" readonly tabindex="-1" />
                        <label class="checkout-v2__floating-label">Expiry (MM / YY)</label>
                      </div>
                      <div class="checkout-v2__input-wrap" style="flex:1">
                        <input type="text" placeholder=" " class="checkout-v2__input" value="" readonly tabindex="-1" />
                        <label class="checkout-v2__floating-label">Security code</label>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Klarna -->
                <div class="checkout-v2__panel">
                  <div class="checkout-v2__panel-header" role="button" tabindex="0" aria-expanded="false">
                    <div class="checkout-v2__radio"></div>
                    <span class="checkout-v2__method-name">Klarna</span>
                    <div class="checkout-v2__icons"></div>
                  </div>
                </div>

                <!-- PayPal -->
                <div class="checkout-v2__panel">
                  <div class="checkout-v2__panel-header" role="button" tabindex="0" aria-expanded="false">
                    <div class="checkout-v2__radio"></div>
                    <span class="checkout-v2__method-name">PayPal</span>
                    <div class="checkout-v2__icons"></div>
                  </div>
                </div>
              </div>

              <button class="checkout-v2__applepay-big" type="button" tabindex="-1">Check Out Now</button>
            </div>
          </div>
        </div>

        {/* Floating outcome chips — decorative narration of the product story:
            customer pays, books reconcile, money lands. Generic amounts only. */}
        <div class="hero-stage__chips" aria-hidden="true">
          <StatusChip class="hero-chip hero-chip--1" tone="success" icon="check" label="Payment received" value="£850.00" />
          <StatusChip class="hero-chip hero-chip--2" tone="neutral" icon="refresh" label="Matched to invoice INV-2041" />
          <StatusChip class="hero-chip hero-chip--3" tone="neutral" icon="banknotes" label="Paid out to your bank" />
        </div>
      </div>
    </div>
  </div>
</section>
