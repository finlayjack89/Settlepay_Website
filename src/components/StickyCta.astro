---
/**
 * StickyCta — the mobile enquiry panel that rises from the bottom of the screen.
 *
 * Two deliberate properties, both asked for directly:
 * 1. CONTEXTUAL — it appears only while a value-demonstrating section is on
 *    screen (Our Work, the comparison matrix, the ROI calculator), and stands
 *    aside for the hero, the final CTA band and the footer. SiteScripts drives
 *    this with an IntersectionObserver.
 * 2. COMPACT — one action plus one reassurance line, and nothing else. It fills
 *    the width and reaches the bottom of the layout viewport; it does not earn
 *    height by stacking copy.
 *
 * Opaque rather than frosted on purpose: a solid surface is what reads as
 * "filled", and it dodges the iOS backdrop-filter clipping quirks. On the
 * unreachable strip below the layout viewport, see the note in the CSS.
 */
import { SITE } from '../data/site.mjs';
import Button from './Button.astro';
---
<div class="sticky-cta" data-sticky-cta>
  <div class="sticky-cta__panel">
    <Button variant="primary" size="large" icon="arrow" enquire data-enquire-source="sticky-cta">
      {SITE.cta.primary.label}
    </Button>
    <p class="sticky-cta__note">Free and no obligation — a reply within one working day.</p>
  </div>
</div>

<style>
  .sticky-cta {
    /* Do NOT try to overscan this panel past `bottom: 0` to chase the strip
       behind Safari's floating toolbar. That strip is outside the layout
       viewport and every fixed layer is clipped to it — measured four ways on
       an iPhone 17 Pro Max / iOS 26 (a separate overscan element, a ::after,
       a negative `bottom` on this box, and `theme-color`: all no-ops). What
       shows there is the scrolling document, which only the body background can
       replace, and only while the document is scroll-locked — which is exactly
       why the modal veil fix works and this cannot. */
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 90; /* below the nav (100) and the modal overlay (1000) */
    display: none; /* desktop: never */
    background: var(--color-pure-white);
    border-radius: var(--radius-card) var(--radius-card) 0 0;
    /* env() needs an explicit fallback — without one the whole calc() is
       invalidated on engines that don't support it. */
    padding: 1.15rem 1.25rem calc(1.15rem + env(safe-area-inset-bottom, 0px));
    box-shadow:
      0 -1px 0 rgba(15, 23, 42, 0.05),
      0 -18px 48px rgba(15, 23, 42, 0.16);
    /* Off-screen + non-focusable until shown; visibility flips after the slide. */
    transform: translateY(110%);
    visibility: hidden;
    transition:
      transform 420ms var(--curve-spring),
      visibility 0s linear 420ms;
  }

  @media (max-width: 768px) {
    .sticky-cta { display: block; }
  }

  .sticky-cta.is-visible {
    transform: translateY(0);
    visibility: visible;
    transition:
      transform 420ms var(--curve-spring),
      visibility 0s;
  }

  .sticky-cta__panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.9rem;
  }

  .sticky-cta :global(.btn-primary) {
    width: 100%;
    max-width: 420px;
    justify-content: center;
  }

  .sticky-cta__note {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-cta { transition: visibility 0s; }
  }
</style>
