# Copy to outreach/.env and fill in. NEVER commit the real .env (it is gitignored).
# One key per process. Each secret's name here is identical to its Secret Manager
# secret AND to the name code reads (outreach/config.py) — deploy maps NAME=NAME:latest.
# Supabase project: xqpbcoldcqfxfwhcqlcy

# ── Pipeline datastore ─ every stage's state: leads, enrichment, drafts, sends,
# replies, suppression, jobs queue, spend ledger.
# Privileged Postgres connection (psycopg), server-side only.
# Use the SESSION POOLER string (Dashboard -> Connect -> Session pooler) — IPv4, DDL-capable.
# The direct host db.<ref>.supabase.co is IPv6-only and may not resolve.
DATABASE_URL=postgresql://postgres.<ref>:YOUR_DB_PASSWORD@aws-1-<region>.pooler.supabase.com:5432/postgres

# Pipeline schema (its own; never touches the website's public tables).
DB_SCHEMA=outreach
# Website inbound-enquiry source to suppress against (public schema): leads -> enquiries after repoint.
ENQUIRY_SOURCE_TABLE=leads

# ── Lead discovery ─ Companies House Advanced Search: finds candidate companies by
# SIC code / age / status (free): developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=
CH_MAX_REQUESTS_PER_RUN=50

# ── Local discovery ─ Google Maps Platform (Places API New + Geocoding): finds LOCAL
# ICP businesses by town × vertical; billed to the GCP credit. Restrict the key to
# Places API (New) + Geocoding only.
GOOGLE_MAPS_API_KEY=

# ── Email verification ─ MillionVerifier: deliverability check on every address
# before it can be contacted (paid per-verify; metered into the spend ledger)
MILLIONVERIFIER_API_KEY=
MV_MAX_PER_RUN=20

# ── Website discovery & enrichment ─ resolves each company to its website and pulls
# page text for payment-behaviour signals: inline (attended) | firecrawl | brave
# Firecrawl free = 1,000 credits/mo (~500 searches), no card. Brave = $5/1k, card required.
WEBSITE_RESOLVER=inline
FIRECRAWL_API_KEY=
BRAVE_SEARCH_API_KEY=
SEARCH_MAX_REQUESTS_PER_RUN=50

# ── Drafting brain ─ writes enrichment signals + email drafts (and follow-ups).
# inline (attended; loop agent) | api (unattended — the headless "brain")
LLM_PROVIDER=inline
# Anthropic key (console label: settlepay-outreach-drafting) + model
# (verified against ~/.claude/LLM_MODELS.md)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- autonomy (full-chain tick). Off => a bare tick stays classify+send only. ---
PIPELINE_AUTONOMOUS=0
DISCOVER_PER_TICK=10
ENRICH_PER_TICK=10
DRAFT_PER_TICK=10
FOLLOWUP_PER_TICK=10
INBOUND_MAX_PER_RUN=50
# CSV of SIC codes to discover; empty = the ICP sweep (targeting.TARGET_SICS)
TARGET_SIC_CODES=
# graduation auto-approve (lights-out per vertical) — double-gated with sequence_config
AUTO_APPROVE_ENABLED=0

# --- spend cap (hard stop across paid providers; ledger = outreach.spend) ---
MONTHLY_SPEND_CAP_GBP=50
# token->GBP conversion (claude-sonnet-4-6 list prices; update on model change)
ANTHROPIC_INPUT_USD_PER_MTOK=3.0
ANTHROPIC_OUTPUT_USD_PER_MTOK=15.0
USD_TO_GBP=0.79
MV_COST_GBP_PER_VERIFY=0.003

# ── Operator alerts ─ kill-switch trips and daily digests are mailed here
# (transactional; sends even when kill switch is on)
OPERATOR_EMAIL=

# ── Dashboard login ─ guards the Cloud Run console at settlepay.uk/dashboard.
# Path prefix when proxied at settlepay.uk/dashboard ("" for localhost dev).
BASE_PATH=
# Auth is ENFORCED only when BOTH are set (local dev stays open on localhost).
# Mint the hash: python -m outreach hash-password · secret: openssl rand -hex 32
CONSOLE_PASSWORD_HASH=
SESSION_SECRET=
SESSION_TTL_HOURS=12
# Cloud Scheduler OIDC for POST /tick (service-account email + Cloud Run URL)
TICK_INVOKER_SA=
TICK_AUDIENCE=

# --- Clay integration (Phase 7 — seams only; leave unset until DPA signed) ---
# CLAY_ENABLED=0
# CLAY_WEBHOOK_URL=
# CLAY_CALLBACK_SECRET=
# CLAY_MAX_PER_RUN=25

# ── Email send + inbound read ─ Gmail API as the sending mailbox: outbound sends (dry-run
# until gate G-SEND) and reply/bounce/unsubscribe ingestion. Google Workspace secondary
# domain, never @settlepay.uk. Generate the refresh token once: python -m outreach auth-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=        # durable credential — never commit or log
GMAIL_SENDER=               # e.g. finlay@getsettlepay.uk
# Google tolerates a higher cold limit (~18-22/inbox/day) than M365 — keep low for now.
PER_INBOX_DAILY_CAP=5
KILL_SWITCH=          # set truthy to block ALL sends (kill switch)

# G_SEND — human-only live-send gate. Leave UNSET. The loop must never set it.
