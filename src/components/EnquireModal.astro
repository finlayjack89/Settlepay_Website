---
/**
 * EnquireModal — the free-consultation form. Opened by any [data-enquire] button.
 * Submission is progressively enhanced: it POSTs to SITE.formEndpoint when set,
 * otherwise falls back to a mailto: so it works with no backend (localhost).
 * Visitors who'd rather self-schedule can jump straight to /book/.
 */
import { SITE } from '../data/site.mjs';
import Icon from './Icon.astro';
import Button from './Button.astro';
---
<div
  class="sp-modal-overlay"
  id="enquire-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="enquire-title"
  hidden
>
  <!-- Coverage and frost are separate layers: iOS clips a backdrop-filtered
       element's paint to the layout viewport it can sample, so the filtered
       layer can never reach the status-bar/toolbar zones — the filter-free
       overscanned scrim covers those instead. Styles in kit-extras.css. -->
  <div class="sp-modal__scrim" aria-hidden="true"></div>
  <div class="sp-modal__frost" aria-hidden="true"></div>
  <div class="sp-modal">
    <button class="sp-modal__close" data-modal-close aria-label="Close consultation form">
      <Icon name="close" sw={2} />
    </button>

    <div class="sp-modal__view" data-modal-form>
      <div class="sp-modal__head">
        <div class="section-badge">Free Consultation</div>
        <h3 class="sp-modal__title" id="enquire-title">Tell Us About Your Payments</h3>
        <p class="sp-modal__sub">
          No obligation. We'll review your current workflow and show you what's possible.
        </p>
      </div>

      <form
        class="sp-modal__form"
        data-enquire-form
        data-endpoint={SITE.formEndpoint}
        data-mailto={SITE.email}
        novalidate
      >
        <div class="sp-field">
          <input required name="business" id="f-business" placeholder=" " autocomplete="organization" />
          <label for="f-business">Business name</label>
        </div>
        <div class="sp-field">
          <input required name="name" id="f-name" placeholder=" " autocomplete="name" />
          <label for="f-name">Your name</label>
        </div>
        <div class="sp-field">
          <input required type="email" name="email" id="f-email" placeholder=" " autocomplete="email" />
          <label for="f-email">Email address</label>
        </div>
        <div class="sp-field sp-field--area">
          <textarea required name="message" id="f-message" rows="4" placeholder=" "></textarea>
          <label for="f-message">How can we help?</label>
        </div>
        <p class="sp-field__hint">
          Tell us why you're reaching out, the payment system you use today, and what you'd like to
          discuss.
        </p>
        <!-- Honeypot: bots fill this; humans never see it. -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0" />
        <!-- Funnel context (e.g. which preview the enquirer generated) — set by JS. -->
        <input type="hidden" name="context" value="" />
        <!-- Trust is zone-local: reassurance sits at the point of commitment. -->
        <ul class="sp-modal__assure" aria-label="What to expect">
          <li><Icon name="check" sw={2.5} />No card details requested</li>
          <li><Icon name="check" sw={2.5} />A reply within one working day</li>
          <li><Icon name="check" sw={2.5} />Payments are processed by FCA-regulated partners</li>
        </ul>
        <div class="sp-modal__submit">
          <Button type="submit" icon="arrow" data-submit-btn>Send My Enquiry</Button>
        </div>
        <p class="sp-field__hint">
          By submitting, you agree to our <a href="/privacy/">Privacy Policy</a>.
        </p>
        <p class="sp-field__hint" data-form-note hidden aria-live="polite"></p>
        <p class="sp-field__hint" data-form-error hidden role="alert" aria-live="assertive" style="color:var(--color-error)"></p>
      </form>
    </div>

    <!-- Non-scrolling footer: the self-schedule fork must never hide below the
         form's internal scroll fold — both funnel paths stay on screen. -->
    <div class="sp-modal__footer" data-modal-footer>
      <div class="sp-modal__or"><span>or</span></div>
      <a href="/book/" class="btn-secondary sp-modal__book">
        Pick a Time Now<Icon name="arrow" sw={2.5} />
      </a>
      <p class="sp-field__hint sp-modal__alt-note">
        Prefer email? Write to us at <a href="mailto:hello@settlepay.uk">hello@settlepay.uk</a>
      </p>
    </div>

    <div class="sp-modal__success" data-modal-success hidden>
      <div class="sp-modal__success-icon"><Icon name="check" sw={2.5} /></div>
      <h3>Thank You — Your Enquiry Is In</h3>
      <p>
        Finlay, SettlePay's founder, will email you within one working day to arrange your free,
        no-obligation consultation. Keep an eye on your inbox for a confirmation.
      </p>
      <a href="/book/" class="btn-primary sp-modal__book">
        Skip the Wait — Pick a Time Now<Icon name="arrow" sw={2.5} />
      </a>
      <button type="button" class="sp-modal__success-close" data-modal-close>Close</button>
    </div>
  </div>
</div>

<style>
  /* Let the [hidden] attribute win over the flex display from kit-extras.css. */
  .sp-modal-overlay[hidden] { display: none; }
  .sp-modal__success[hidden] { display: none; }
  .sp-modal__view[hidden] { display: none; }

  /* Smooth cross-fade when the form is swapped for the thank-you confirmation. */
  @keyframes spSuccessIn {
    from { opacity: 0; transform: translateY(8px) scale(0.99); }
    to   { opacity: 1; transform: none; }
  }
  /* --curve-*, not --ease-*: the ease shorthands bundle a duration, which the
     animation shorthand would parse as a DELAY — visible as an open-then-blink. */
  .sp-modal__success:not([hidden]) { animation: spSuccessIn 0.32s var(--curve-cinematic); }
  @media (prefers-reduced-motion: reduce) {
    .sp-modal__success:not([hidden]) { animation: none; }
  }

  /* The submit pins to the bottom of the scrolling view while it is below
     the fold, and releases at its natural position — inert (zero visual
     change) whenever the modal fits the viewport without overflowing. */
  .sp-modal__submit {
    position: sticky;
    bottom: 0;
    z-index: 2;
    background: var(--color-pure-white);
  }
  /* Top fade so content scrolls under cleanly. While unpinned the strip
     sits entirely inside the empty gap above the button — invisible. */
  .sp-modal__submit::before {
    content: '';
    position: absolute;
    top: -14px;
    left: 0;
    right: 0;
    height: 14px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--color-pure-white));
    pointer-events: none;
  }

  /* Zone-local reassurance at the submit button. */
  .sp-modal__assure {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin: 0.2rem 0 0.55rem;
  }
  .sp-modal__assure li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .sp-modal__assure li :global(svg) {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    color: var(--color-success);
  }

  /* Pinned footer: sits outside the scrolling view, hidden on success. */
  .sp-modal__footer {
    flex-shrink: 0;
    padding-top: 0.55rem;
    margin-top: 0.55rem;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }
  .sp-modal__footer[hidden] { display: none; }

  /* "or" divider between the form and the self-schedule shortcut. */
  .sp-modal__or {
    display: flex; align-items: center; text-align: center;
    gap: 0.75rem; margin: 0.4rem 0 0.1rem;
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: rgba(15, 23, 42, 0.4);
  }
  .sp-modal__or::before,
  .sp-modal__or::after {
    content: ''; flex: 1; height: 1px; background: rgba(15, 23, 42, 0.1);
  }

  /* Self-schedule shortcut, styled to fill the modal like the submit button. */
  .sp-modal__book {
    width: 100%; box-sizing: border-box;
    display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
    text-decoration: none;
  }
  .sp-modal__success .sp-modal__book { margin-bottom: 0.85rem; }
  .sp-modal__alt-note { text-align: center; margin-top: 0.1rem; }

  .sp-modal__success-close {
    background: none; border: none; cursor: pointer;
    font: inherit; font-size: 0.85rem; color: var(--color-primary-brand);
    opacity: 0.55; text-decoration: underline; padding: 0.25rem;
    transition: opacity var(--ease-snappy);
  }
  .sp-modal__success-close:hover { opacity: 0.85; }

  /* The submit button shows a non-interactive "Sending…" state mid-request. */
  .sp-modal__form [data-submit-btn][aria-busy='true'] {
    opacity: 0.8; cursor: progress;
  }
</style>
