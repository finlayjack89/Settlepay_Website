---
/**
 * /p/<slug> — shareable, view-only preview page.
 *
 * A share link (created from /preview/) resolves here: the slug is parsed
 * client-side (a Vercel rewrite maps /p/<slug> onto this static page; ?s=<slug>
 * also works everywhere, including local dev), the snapshot is fetched from the
 * brand-preview function and painted with the same painter as /preview/.
 * Recipients get the device + appearance toggles but no customisation — this is
 * the pitch, plus a booking CTA.
 *
 * Lockdown, honestly: the page deters casual copying (no text selection on the
 * mockup, context menu blocked, no customisation) — a screenshot is always
 * possible and the link itself is an invitation to look. Snapshots are created
 * server-side from pipeline-validated content only. noindex + robots-disallowed.
 */
import '../../styles/portfolio.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';
import PaymentPagePreview from '../../components/preview/PaymentPagePreview.astro';
import { SITE } from '../../data/site.mjs';
---
<BaseLayout
  title="Your Payment Page Preview | SettlePay"
  description="An illustrative branded payment-page preview, designed with SettlePay."
  canonical="/p/"
  image="/og/preview.png"
  noindex
>
  <section class="pshare section-pad" data-pshare data-endpoint={SITE.previewEndpoint}>
    <div class="container">
      <header class="pshare__head">
        <div class="section-badge">Payment Page Preview</div>
        <h1 class="pshare__title" data-pshare-title>Loading Your Preview…</h1>
        <p class="pshare__lead" data-pshare-lead>
          An illustrative payment page designed with SettlePay.
        </p>
      </header>

      <!-- share not found / expired -->
      <div class="pshare__error" data-pshare-error hidden>
        <p class="pshare__error-text">
          This preview link has expired or doesn't exist. Previews are kept for 30 days —
          but making a new one takes seconds.
        </p>
        <Button variant="primary" icon="arrow" href="/preview/">See Your Payment Page</Button>
      </div>

      <div class="pshare__body" data-pshare-body>
        <div class="pshare__viewbar">
          <div class="pshare__seg" role="radiogroup" aria-label="Device">
            <button type="button" class="pshare__seg-btn" data-pshare-device="mobile" role="radio" aria-checked="false">
              <Icon name="mobile" sw={1.8} /> Mobile
            </button>
            <button type="button" class="pshare__seg-btn" data-pshare-device="desktop" role="radio" aria-checked="false">
              <Icon name="desktop" sw={1.8} /> Desktop
            </button>
          </div>
          <div class="pshare__seg" role="radiogroup" aria-label="Appearance">
            <button type="button" class="pshare__seg-btn" data-pshare-theme="light" role="radio" aria-checked="false">
              <Icon name="sun" sw={1.8} /> Light
            </button>
            <button type="button" class="pshare__seg-btn" data-pshare-theme="dark" role="radio" aria-checked="false">
              <Icon name="moon" sw={1.8} /> Dark
            </button>
          </div>
        </div>

        <div class="pshare__cards">
          <div class="pshare__frame" data-pshare-frame>
            <PaymentPagePreview />
            <div class="pshare__skeleton" data-pshare-skeleton aria-hidden="true">
              <span></span><span></span><span></span><span></span><span></span>
            </div>
            <noscript>
              <!-- Without JS the skeleton would shimmer forever — say so instead. -->
              <style>.pshare__skeleton { display: none; }</style>
              <p class="pshare__noscript">
                This shared preview needs JavaScript to load. Enable JavaScript, or
                <a href="/preview/">make your own preview here</a>.
              </p>
            </noscript>
          </div>
        </div>

        <div class="pshare__tools">
          <button type="button" class="pshare__tool" data-pshare-copy>
            <Icon name="globe" sw={1.8} />
            <span data-pshare-copy-label>Copy Shareable Link</span>
          </button>
          <button type="button" class="pshare__tool" data-pshare-download>
            <Icon name="download" sw={1.8} />
            <span data-pshare-download-label>Download as Image</span>
          </button>
        </div>

        <div class="pshare__cta">
          <p class="pshare__cta-text">
            Want a page like this for your business? SettlePay designs and builds bespoke
            branded payment pages for small UK businesses.
          </p>
          <div class="pshare__cta-actions">
            <Button variant="primary" icon="arrow" enquire>{SITE.cta.primary.label}</Button>
            <Button variant="secondary" href={SITE.cta.secondary.href}>{SITE.cta.secondary.label}</Button>
          </div>
          <p class="pshare__disclaimer" data-pshare-disclaimer></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pshare__head { text-align: center; max-width: 640px; margin: 0 auto 2.2rem; }
  .pshare__title {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-primary-brand);
    margin: 0.9rem 0 0.7rem;
  }
  .pshare__lead { font-size: 1.02rem; line-height: 1.6; color: rgba(15, 23, 42, 0.62); margin: 0; }

  .pshare__error {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }
  .pshare__error[hidden] { display: none; }
  .pshare__error-text { font-size: 1rem; line-height: 1.6; color: rgba(15, 23, 42, 0.62); margin: 0; }

  .pshare__body[hidden] { display: none; }
  .pshare__viewbar {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }
  .pshare__seg {
    display: inline-flex;
    background: var(--color-secondary-bg);
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: var(--radius-button);
    padding: 4px;
    gap: 2px;
  }
  .pshare__seg-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(15, 23, 42, 0.62);
    background: transparent;
    border: 0;
    border-radius: var(--radius-button);
    padding: 0.42rem 0.85rem;
    cursor: pointer;
    transition: background var(--ease-snappy), color var(--ease-snappy);
  }
  .pshare__seg-btn.is-selected {
    background: var(--color-pure-white);
    color: var(--color-primary-brand);
    box-shadow: var(--shadow-sm);
  }
  .pshare__seg-btn:focus-visible { outline: 2px solid var(--color-primary-action); outline-offset: 2px; }
  .pshare__seg-btn :global(svg) { width: 15px; height: 15px; }

  .pshare__cards {
    display: grid;
    grid-template-columns: minmax(0, 480px);
    justify-content: center;
  }
  .pshare--desktop .pshare__cards { grid-template-columns: minmax(0, 820px); }
  /* View-only: deter casual copying (screenshots are always possible — this is a
     deterrent, not a vault). */
  .pshare__frame { position: relative; user-select: none; -webkit-user-select: none; }

  .pshare__skeleton {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: 18px;
    background: var(--color-pure-white);
    border: 1px solid rgba(15, 23, 42, 0.06);
    padding: 2.4rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    overflow: hidden;
  }
  .pshare__skeleton[hidden] { display: none; }
  .pshare__noscript {
    padding: 2.5rem 1.5rem;
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  .pshare__noscript a { color: var(--color-primary-action); text-decoration: underline; }
  .pshare__skeleton span {
    display: block;
    border-radius: 8px;
    background: linear-gradient(100deg, rgba(15, 23, 42, 0.06) 40%, rgba(15, 23, 42, 0.12) 50%, rgba(15, 23, 42, 0.06) 60%);
    background-size: 200% 100%;
    animation: pshare-shimmer 1.4s ease-in-out infinite;
  }
  .pshare__skeleton span:nth-child(1) { height: 34px; width: 55%; }
  .pshare__skeleton span:nth-child(2) { height: 56px; }
  .pshare__skeleton span:nth-child(3) { height: 90px; }
  .pshare__skeleton span:nth-child(4) { height: 44px; width: 80%; }
  .pshare__skeleton span:nth-child(5) { height: 44px; }
  @keyframes pshare-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .pshare__tools {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }
  .pshare__tool {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary-brand);
    background: var(--color-pure-white);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: var(--radius-button);
    padding: 0.6rem 1.2rem;
    cursor: pointer;
    transition: background var(--ease-snappy), transform var(--ease-snappy);
  }
  .pshare__tool:hover:not(:disabled) { background: var(--color-secondary-bg); }
  .pshare__tool:active:not(:disabled) { transform: scale(0.98); }
  .pshare__tool:disabled { cursor: default; opacity: 0.6; }
  .pshare__tool svg { width: 16px; height: 16px; color: var(--color-primary-action); }

  .pshare__cta {
    max-width: 820px;
    margin: 2rem auto 0;
    padding: 1.4rem 1.6rem;
    background: var(--color-secondary-bg);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  .pshare__cta-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-primary-brand);
    flex: 1 1 320px;
  }
  .pshare__cta-actions { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .pshare__disclaimer {
    flex-basis: 100%;
    margin: 0.4rem 0 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: rgba(15, 23, 42, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .pshare__seg-btn { transition: none; }
    .pshare__skeleton span { animation: none; }
  }
</style>

<script>
  import { resolveBrief, paintBrief } from '../../scripts/paymentPage.mjs';
  import { slugify } from '../../scripts/brandReskin.mjs';

  const FONT_LINK_ID = 'pshare-brand-font';
  const FONT_OK = (f) =>
    typeof f === 'string' && /^[A-Za-z0-9][A-Za-z0-9 '\-]{1,39}$/.test(f.trim()) && !/var|--|[(),;]/.test(f);

  function loadBrandFont(family) {
    const existing = document.getElementById(FONT_LINK_ID);
    if (existing) existing.remove();
    if (!family || !FONT_OK(family)) return;
    const link = document.createElement('link');
    link.id = FONT_LINK_ID;
    link.rel = 'stylesheet';
    link.href =
      'https://fonts.googleapis.com/css2?family=' +
      encodeURIComponent(family).replace(/%20/g, '+') +
      ':wght@400;600;700&display=swap';
    document.head.appendChild(link);
  }

  document.querySelectorAll('[data-pshare]').forEach((root) => {
    if (root.dataset.pshareBound) return;
    root.dataset.pshareBound = '1';

    const endpoint = root.dataset.endpoint || '';
    const titleEl = root.querySelector('[data-pshare-title]');
    const leadEl = root.querySelector('[data-pshare-lead]');
    const errorEl = root.querySelector('[data-pshare-error]');
    const bodyEl = root.querySelector('[data-pshare-body]');
    const frameEl = root.querySelector('[data-pshare-frame]');
    const skeleton = root.querySelector('[data-pshare-skeleton]');
    const disclaimerEl = root.querySelector('[data-pshare-disclaimer]');
    const deviceBtns = root.querySelectorAll('[data-pshare-device]');
    const themeBtns = root.querySelectorAll('[data-pshare-theme]');
    const copyBtn = root.querySelector('[data-pshare-copy]');
    const copyLabel = root.querySelector('[data-pshare-copy-label]');
    const downloadBtn = root.querySelector('[data-pshare-download]');
    const downloadLabel = root.querySelector('[data-pshare-download-label]');

    // Deter casual copying inside the mockup only — the rest of the page is normal.
    frameEl.addEventListener('contextmenu', (e) => e.preventDefault());
    frameEl.addEventListener('dragstart', (e) => e.preventDefault());

    const state = {
      snapshot: null,
      slug: '',
      overrides: {
        accent: null,
        scenario: null,
        device: window.matchMedia('(max-width: 860px)').matches ? 'mobile' : 'desktop',
        theme: null, // null = the design's preferred rendition until toggled
      },
    };

    function syncToggles() {
      const theme =
        state.overrides.theme ||
        (state.snapshot ? state.snapshot.variant.brief.design.preferred : 'light');
      deviceBtns.forEach((b) => {
        const on = b.dataset.pshareDevice === state.overrides.device;
        b.classList.toggle('is-selected', on);
        b.setAttribute('aria-checked', on ? 'true' : 'false');
      });
      themeBtns.forEach((b) => {
        const on = b.dataset.pshareTheme === theme;
        b.classList.toggle('is-selected', on);
        b.setAttribute('aria-checked', on ? 'true' : 'false');
      });
    }

    function render() {
      if (!state.snapshot) return;
      const s = state.snapshot;
      paintBrief(
        frameEl,
        resolveBrief(s.variant, s.brand || {}, state.overrides),
        { name: s.name, host: s.domain },
      );
      root.classList.toggle('pshare--desktop', state.overrides.device === 'desktop');
      syncToggles();
    }

    deviceBtns.forEach((b) =>
      b.addEventListener('click', () => { state.overrides.device = b.dataset.pshareDevice; render(); })
    );
    themeBtns.forEach((b) =>
      b.addEventListener('click', () => { state.overrides.theme = b.dataset.pshareTheme; render(); })
    );

    // The recipient gets the same tools as the creator: re-share this exact
    // link, or download the render in whatever device/appearance they're viewing.
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const link = location.origin + '/p/' + state.slug;
        try {
          await navigator.clipboard.writeText(link);
          if (copyLabel) copyLabel.textContent = 'Link Copied';
        } catch {
          if (copyLabel) copyLabel.textContent = 'Copy Failed';
        }
        setTimeout(() => { if (copyLabel) copyLabel.textContent = 'Copy Shareable Link'; }, 2200);
      });
    }
    if (downloadBtn) {
      downloadBtn.addEventListener('click', async () => {
        if (!state.slug || !endpoint) return;
        downloadBtn.disabled = true;
        if (downloadLabel) downloadLabel.textContent = 'Preparing Image…';
        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              renderShare: {
                slug: state.slug,
                device: state.overrides.device,
                theme: state.overrides.theme || '',
              },
            }),
          });
          if (!res.ok || !(res.headers.get('content-type') || '').startsWith('image/')) throw new Error('render-failed');
          const blob = await res.blob();
          const ext = blob.type.includes('jpeg') ? 'jpg' : 'png';
          const name = state.snapshot ? slugify(state.snapshot.name) : 'settlepay';
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = name + '-payment-page.' + ext;
          document.body.appendChild(a);
          a.click();
          a.remove();
          setTimeout(() => URL.revokeObjectURL(a.href), 10_000);
          if (downloadLabel) downloadLabel.textContent = 'Downloaded';
        } catch {
          if (downloadLabel) downloadLabel.textContent = "Couldn't Prepare Image";
        } finally {
          downloadBtn.disabled = false;
          setTimeout(() => { if (downloadLabel) downloadLabel.textContent = 'Download as Image'; }, 2600);
        }
      });
    }

    function fail() {
      if (bodyEl) bodyEl.hidden = true;
      if (errorEl) errorEl.hidden = false;
      if (titleEl) titleEl.textContent = 'Preview Not Found';
      if (leadEl) leadEl.textContent = 'The link may have expired — previews are kept for 30 days.';
    }

    async function load() {
      // Path style (/p/<slug>, via the Vercel rewrite) or ?s=<slug> everywhere else.
      const fromPath = (location.pathname.match(/^\/p\/([a-z0-9]{8,16})\/?$/i) || [])[1];
      const slug = (fromPath || new URLSearchParams(location.search).get('s') || '').toLowerCase();
      if (!slug || !endpoint) { fail(); return; }
      state.slug = slug;
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ share: { slug } }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data || data.error || !data.share || !data.variant) throw new Error('share-failed');
        state.snapshot = { name: data.name, domain: data.domain, brand: data.brand, variant: data.variant };
        loadBrandFont((data.brand && data.brand.font) || '');
        if (titleEl) titleEl.textContent = data.name + "'s Payment Page";
        if (leadEl) {
          leadEl.textContent =
            'An illustrative preview designed from ' + data.domain + "'s public branding by SettlePay.";
        }
        document.title = data.name + "'s Payment Page Preview | SettlePay";
        if (disclaimerEl) {
          disclaimerEl.textContent =
            'Illustrative preview — a sketch generated from public branding, not affiliated with or ' +
            'endorsed by ' + data.name + '. No real payments are taken.';
        }
        if (skeleton) skeleton.hidden = true;
        render();
      } catch (err) {
        fail();
      }
    }

    syncToggles();
    load();
  });
</script>
