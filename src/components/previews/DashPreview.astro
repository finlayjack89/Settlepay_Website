---
/* Value-prop mockup: an unbranded merchant payments dashboard (no PSP name shown). */
import Chrome from './Chrome.astro';
const kpis = [
  { label: 'Net volume', value: '£48,210', delta: '+12.4%', dir: 'up' },
  { label: 'Payments', value: '1,284', delta: '+6.1%', dir: 'up' },
  { label: 'Avg. settle', value: '1.2 days', delta: 'Steady', dir: 'flat' },
];
const axis = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
---
<div class="mok dashx">
  <Chrome url="app.meridianstudio.com" />
  <div class="dashx__topbar">
    <div class="dashx__logo dashx__logo--mark">M</div>
    <div class="dashx__brand">
      <span class="dashx__brand-name">Meridian</span>
      <span class="dashx__brand-sub">Studio</span>
    </div>
    <span class="dashx__live">Live</span>
    <div class="dashx__avatar">MS</div>
  </div>
  <div class="dashx__body">
    <div class="dashx__kpis">
      {kpis.map((k) => (
        <div class="dashx__kpi">
          <div class="dashx__kpi-label">{k.label}</div>
          <div class="dashx__kpi-value">{k.value}</div>
          <div class={'dashx__kpi-delta dashx__kpi-delta--' + k.dir}>
            {k.dir === 'up' ? '↑ ' + k.delta : k.delta}
          </div>
        </div>
      ))}
    </div>
    <div class="dashx__chartcard">
      <div class="dashx__chart-head">
        <div class="dashx__chart-title">Net volume · last 7 days</div>
        <div class="dashx__chart-amount">£48,210<span>↑ 12.4%</span></div>
      </div>
      <div class="dashx__chart">
        <svg viewBox="0 0 400 100" fill="none" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="dashxFill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3B82F6" stop-opacity="0.22" />
              <stop offset="100%" stop-color="#3B82F6" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path
            d="M0 78 C40 70, 60 80, 100 60 C140 40, 170 52, 210 38 C250 24, 280 44, 320 26 C355 11, 380 20, 400 12"
            stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          />
          <path
            d="M0 78 C40 70, 60 80, 100 60 C140 40, 170 52, 210 38 C250 24, 280 44, 320 26 C355 11, 380 20, 400 12 L400 100 L0 100 Z"
            fill="url(#dashxFill)"
          />
          <circle cx="400" cy="12" r="3.5" fill="#3B82F6" />
        </svg>
      </div>
      <div class="dashx__chart-axis">
        {axis.map((d) => <span>{d}</span>)}
      </div>
    </div>
  </div>
</div>
