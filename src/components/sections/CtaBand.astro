---
import Button from '../Button.astro';
import Icon from '../Icon.astro';
import PayCard from '../PayCard.astro';
import { SITE } from '../../data/site.mjs';
---
<section class="cta-section" id="enquire" data-screen-label="CTA band">
  <div class="container">
    <div class="cta-section__inner">
      <div class="cta-section__content">
        <h2 class="cta-section__title">Ready to Stop Chasing Bank Transfers?</h2>
        <p class="cta-section__text">
          Send us a short enquiry — free and no-obligation. We'll review your current payment
          workflow and show you exactly how a bespoke checkout page, with payments processed by an
          FCA-regulated processor, can eliminate the admin.
        </p>
        {/* Reassurance beat at the risk-anxiety peak — for the already-sold, right before the ask. */}
        <ul class="cta-section__trust" aria-label="Why businesses trust SettlePay">
          {SITE.trustPoints.map((t) => (
            <li class="cta-section__trust-item">
              <Icon name={t.icon} sw={1.75} />
              <span>{t.title}</span>
            </li>
          ))}
        </ul>
        <div class="cta-section__actions">
          <Button variant="primary" size="large" icon="arrow" enquire>{SITE.cta.primary.label}</Button>
          <Button variant="secondary" onDark href={SITE.cta.secondary.href}>{SITE.cta.secondary.label}</Button>
        </div>
      </div>
      <div class="cta-section__card">
        <PayCard />
      </div>
    </div>
  </div>
</section>

<style>
  /* Compact, light-on-dark reassurance strip — deliberately quieter than the top
     TrustBar (no tinted tiles), so it reassures without competing with the CTA. */
  .cta-section__trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.6rem 1.75rem;
    max-width: 660px;
    margin: 0 0 2.25rem;
    padding: 0;
    list-style: none;
  }
  @media (max-width: 880px) {
    .cta-section__trust { justify-content: center; margin-inline: auto; }
  }
  .cta-section__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.72);
  }
  .cta-section__trust-item svg {
    width: 15px;
    height: 15px;
    color: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
  }
  @media (max-width: 480px) {
    .cta-section__trust { gap: 0.55rem 1.1rem; justify-content: flex-start; text-align: left; }
  }
</style>
