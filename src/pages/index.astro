---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ValueProps from '../components/sections/ValueProps.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import MarketShift from '../components/sections/MarketShift.astro';
import FastStart from '../components/sections/FastStart.astro';
import OurWork from '../components/sections/OurWork.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import Calculator from '../components/sections/Calculator.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import CardMoment from '../components/sections/CardMoment.astro';
import PreviewTeaser from '../components/sections/PreviewTeaser.astro';
import Compare from '../components/sections/Compare.astro';
import SecurityEvidence from '../components/sections/SecurityEvidence.astro';
import Sources from '../components/sections/Sources.astro';
import InlineCta from '../components/sections/InlineCta.astro';

import seoData from '../data/content/seo.json';
import { siteGraph } from '../data/structuredData.mjs';

const seo = seoData.find((p) => p.path === '/') ?? {};
const jsonLd = [siteGraph()];
---
<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  canonical="/"
  image="/og/home.png"
  jsonLd={jsonLd}
>
  <Hero />
  <TrustBar />
  <CardMoment />
  <ValueProps />
  <OurWork />
  <InlineCta line="Want a branded checkout like this?" source="after-work" />
  <PreviewTeaser />
  <HowItWorks />
  <MarketShift />
  <FastStart />
  <Compare />
  <InlineCta line="Give your customers the one that actually works." source="after-compare" />
  <SecurityEvidence />
  <Calculator />
  <CtaBand />
  <Sources />
</BaseLayout>
