---
/**
 * StickyCta — mobile-only fixed enquiry bar, matching the site-wide primary
 * ask (SITE.cta.primary opens the enquiry modal).
 * Shown/hidden by SiteScripts via IntersectionObserver: slides in once the hero
 * has scrolled away, and hides over the final CTA band, the footer, and any
 * full-bleed dark section (see below). Homepage + persuasion pages.
 *
 * Fills the bottom, the honest way: verified on a real iPhone, NO web layer —
 * fixed, sticky, or an overscanned bleed — can paint the strip behind iOS
 * Safari's floating toolbar; only normal-flow document content reaches it, and
 * that's the browser's own chrome zone. So the bar is a solid, opaque panel
 * pinned to the bottom of the (small) viewport with safe-area padding: over the
 * site's white content the strip below is body-white and the panel reads as
 * filling the bottom seamlessly. The one case that would expose a dark strip —
 * the bar sitting over a dark section — is removed by suppressing the bar there
 * (SiteScripts observes `.section--dark` with a bottom rootMargin so it also
 * hides while a dark band is in the toolbar strip just below the fold).
 */
import { SITE } from '../data/site.mjs';
import Button from './Button.astro';
---
<div class="sticky-cta" data-sticky-cta>
  <Button variant="primary" size="large" icon="arrow" enquire>{SITE.cta.primary.label}</Button>
</div>

<style>
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 90; /* below the nav (100) and modal overlay */
    display: none; /* desktop: never */
    justify-content: center;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
    /* Opaque, not frosted: a solid panel is what fills the bottom on iOS. A
       backdrop-filter here buys nothing (nothing shows through) and reintroduces
       the iOS filter-clipping quirks that cost three fix rounds. */
    background: var(--color-pure-white);
    box-shadow:
      0 -1px 0 rgba(15, 23, 42, 0.06),
      0 -10px 30px rgba(15, 23, 42, 0.10);
    /* Off-screen + non-focusable until shown; visibility flips after the slide-out. */
    transform: translateY(130%);
    visibility: hidden;
    transition:
      transform 400ms var(--curve-spring),
      visibility 0s linear 400ms;
  }

  @media (max-width: 768px) {
    .sticky-cta { display: flex; }
  }

  .sticky-cta.is-visible {
    transform: translateY(0);
    visibility: visible;
    transition:
      transform 400ms var(--curve-spring),
      visibility 0s;
  }

  .sticky-cta :global(.btn-primary) {
    width: 100%;
    max-width: 420px;
    justify-content: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-cta { transition: visibility 0s; }
  }
</style>
