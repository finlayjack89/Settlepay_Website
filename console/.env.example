# SettlePay operations console — local secrets. Copy to `.env` (gitignored).

# Supabase Postgres connection. In the Supabase dashboard:
#   Project Settings → Database → Connection string → "Session pooler"
# Copy that exact string (it includes the right region host + port) and put your
# DB password in place of [YOUR-PASSWORD]. Keep this secret.
DATABASE_URL=postgresql://postgres.xqpbcoldcqfxfwhcqlcy:[YOUR-PASSWORD]@[HOST].pooler.supabase.com:5432/postgres

# Inbound enquiries table. 'leads' today; switch to 'enquiries' after the planned
# public.leads → public.enquiries rename (coordinate with the outreach pipeline).
ENQUIRY_SOURCE_TABLE=leads
